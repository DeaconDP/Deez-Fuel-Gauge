<Styles xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Style Selector="TextBlock.settings-group-header">
        <Setter Property="FontSize" Value="8" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Foreground" Value="#FF888888" />
        <Setter Property="Margin" Value="0,4,0,2" />
    </Style>
    <Style Selector="TextBlock.subsection-title">
        <Setter Property="FontSize" Value="9" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Foreground" Value="#FFCCCCCC" />
        <Setter Property="VerticalAlignment" Value="Center" />
    </Style>
    <Style Selector="TextBlock.status-text">
        <Setter Property="FontSize" Value="8" />
        <Setter Property="Foreground" Value="#FF888888" />
        <Setter Property="TextTrimming" Value="CharacterEllipsis" />
        <Setter Property="MaxLines" Value="2" />
    </Style>
    <Style Selector="TextBlock.help-text">
        <Setter Property="FontSize" Value="8" />
        <Setter Property="Foreground" Value="#FF666666" />
        <Setter Property="TextWrapping" Value="Wrap" />
        <Setter Property="MaxLines" Value="3" />
    </Style>
    <Style Selector="ToggleSwitch.settings-toggle">
        <Setter Property="FontSize" Value="9" />
        <Setter Property="Foreground" Value="#FFE8E8E8" />
        <Setter Property="Margin" Value="0,0,10,0" />
        <Setter Property="MinHeight" Value="22" />
        <Setter Property="VerticalAlignment" Value="Center" />
    </Style>
    <Style Selector="Button.action-button">
        <Setter Property="FontSize" Value="8.5" />
        <Setter Property="Padding" Value="5,2" />
        <Setter Property="Margin" Value="4,0,0,0" />
    </Style>
    <Style Selector="Border.subsection-divider">
        <Setter Property="Height" Value="1" />
        <Setter Property="Background" Value="#22FFFFFF" />
        <Setter Property="Margin" Value="0,1" />
    </Style>
    <Style Selector="Border.settings-provider-card">
        <Setter Property="Background" Value="#FF0A0A0A" />
        <Setter Property="BorderBrush" Value="#33FFFFFF" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="4" />
        <Setter Property="Padding" Value="6,4" />
    </Style>
</Styles>
