<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="using:DeezFuelGauge.Settings.Controls"
             x:Class="DeezFuelGauge.Settings.Controls.SettingsGroupHeader"
             x:DataType="controls:SettingsGroupHeader">
    <TextBlock Text="{Binding Title, RelativeSource={RelativeSource AncestorType=controls:SettingsGroupHeader}}"
               Classes="settings-group-header" />
</UserControl>
