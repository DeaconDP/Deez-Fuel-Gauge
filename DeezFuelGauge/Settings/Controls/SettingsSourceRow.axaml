<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:settings="using:DeezFuelGauge.Settings"
             xmlns:controls="using:DeezFuelGauge.Settings.Controls"
             x:Class="DeezFuelGauge.Settings.Controls.SettingsSourceRow"
             x:DataType="settings:ProviderSourceViewModel">
    <StackPanel Spacing="2">
        <Grid ColumnDefinitions="*,Auto,Auto">
            <TextBlock Text="{Binding Name}"
                       Classes="subsection-title" />
            <Button Grid.Column="1"
                    Content="Connect"
                    Classes="action-button"
                    IsVisible="{Binding ShowConnect}"
                    Click="Connect_Click" />
            <Button Grid.Column="2"
                    Content="Test"
                    Classes="action-button"
                    IsVisible="{Binding ShowTest}"
                    Click="Test_Click" />
        </Grid>
        <TextBlock Text="{Binding Status}"
                   Classes="status-text" />
        <TextBlock Text="{Binding AutoAuthSummary}"
                   FontSize="8"
                   Foreground="#FF666666"
                   IsVisible="{Binding HasAutoAuth}" />
        <WrapPanel Orientation="Horizontal">
            <CheckBox Content="Enable"
                      Classes="toggle-checkbox"
                      IsVisible="{Binding HasEnableToggle}"
                      IsChecked="{Binding IsEnabled}" />
            <CheckBox Content="Details"
                      Classes="toggle-checkbox"
                      IsVisible="{Binding HasDetailsToggle}"
                      IsChecked="{Binding ShowDetails}" />
            <CheckBox Content="Limits"
                      Classes="toggle-checkbox"
                      IsVisible="{Binding HasLimitsToggle}"
                      IsChecked="{Binding ShowLimits}" />
            <CheckBox Content="Limits"
                      Classes="toggle-checkbox"
                      IsVisible="{Binding HasBreakdownToggle}"
                      IsChecked="{Binding ShowBreakdown}" />
        </WrapPanel>
        <StackPanel Spacing="2"
                    IsVisible="{Binding ShowAdvancedSection}">
            <Button Content="Advanced ▾"
                    Classes="action-button"
                    HorizontalAlignment="Left"
                    Click="AdvancedToggle_Click" />
            <StackPanel Spacing="2"
                        IsVisible="{Binding IsAdvancedExpanded}">
                <TextBlock Text="{Binding AdvancedHint}"
                           FontSize="8"
                           Foreground="#FF666666"
                           TextWrapping="Wrap"
                           MaxLines="3" />
                <Grid ColumnDefinitions="*,Auto"
                      IsVisible="{Binding ShowApiKeyField}">
                    <TextBox x:Name="ApiKeyBox"
                             Grid.Column="0"
                             Watermark="{Binding ApiKeyWatermark}"
                             PasswordChar="•"
                             FontSize="9"
                             LostFocus="ApiKeyBox_LostFocus" />
                    <Button Grid.Column="1"
                            Content="Clear"
                            FontSize="8"
                            Padding="4,2"
                            Margin="4,0,0,0"
                            IsVisible="{Binding HasApiKeySaved}"
                            Click="ClearApiKey_Click" />
                </Grid>
                <Grid ColumnDefinitions="*,Auto"
                      IsVisible="{Binding ShowManagementApiKeyField}">
                    <TextBox x:Name="ManagementApiKeyBox"
                             Grid.Column="0"
                             Watermark="{Binding ManagementApiKeyWatermark}"
                             PasswordChar="•"
                             FontSize="9"
                             LostFocus="ManagementApiKeyBox_LostFocus" />
                    <Button Grid.Column="1"
                            Content="Clear"
                            FontSize="8"
                            Padding="4,2"
                            Margin="4,0,0,0"
                            IsVisible="{Binding HasManagementApiKeySaved}"
                            Click="ClearManagementApiKey_Click" />
                </Grid>
                <Grid ColumnDefinitions="*,8,*"
                      IsVisible="{Binding ShowOrgIdField}">
                    <TextBox Grid.Column="0"
                             Watermark="Org ID (optional)"
                             FontSize="9"
                             Text="{Binding OrgId}" />
                    <TextBox Grid.Column="2"
                             Watermark="Budget USD"
                             FontSize="9"
                             Text="{Binding Budget}"
                             IsVisible="{Binding ShowBudgetField}" />
                </Grid>
                <TextBox Watermark="Budget USD"
                         FontSize="9"
                         Text="{Binding Budget}"
                         IsVisible="{Binding ShowStandaloneBudgetField}" />
                <TextBox Watermark="Workspace ID"
                         FontSize="9"
                         Text="{Binding WorkspaceId}"
                         IsVisible="{Binding ShowWorkspaceField}" />
                <Grid ColumnDefinitions="*,Auto"
                      IsVisible="{Binding ShowSessionField}">
                    <TextBox x:Name="SessionBox"
                             Grid.Column="0"
                             Watermark="{Binding SessionWatermark}"
                             PasswordChar="•"
                             FontSize="9"
                             LostFocus="SessionBox_LostFocus" />
                    <Button Grid.Column="1"
                            Content="Clear"
                            FontSize="8"
                            Padding="4,2"
                            Margin="4,0,0,0"
                            IsVisible="{Binding HasSessionSaved}"
                            Click="ClearSession_Click" />
                </Grid>
            </StackPanel>
        </StackPanel>
    </StackPanel>
</UserControl>
