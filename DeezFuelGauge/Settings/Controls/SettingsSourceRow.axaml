<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:settings="using:DeezFuelGauge.Settings"
             xmlns:controls="using:DeezFuelGauge.Settings.Controls"
             x:Class="DeezFuelGauge.Settings.Controls.SettingsSourceRow"
             x:DataType="settings:ProviderSourceViewModel">
    <StackPanel Spacing="2">
        <Grid ColumnDefinitions="*,Auto,Auto">
            <TextBlock Text="{Binding Name}"
                       Classes="subsection-title" />
            <Button Grid.Column="1"
                    Content="Connect"
                    Classes="action-button"
                    IsVisible="{Binding ShowConnect}"
                    Click="Connect_Click" />
            <Button Grid.Column="2"
                    Content="Test"
                    Classes="action-button"
                    IsVisible="{Binding ShowTest}"
                    Click="Test_Click" />
        </Grid>
        <TextBlock Text="{Binding Status}"
                   Classes="status-text" />
        <TextBlock Text="{Binding AutoAuthSummary}"
                   FontSize="8"
                   Foreground="#FF666666"
                   IsVisible="{Binding HasAutoAuth}" />
        <StackPanel Orientation="Horizontal"
                    Spacing="4"
                    IsVisible="{Binding ShowSignInButton}">
            <Button Content="Sign in with Claude"
                    Classes="action-button"
                    Click="SignInWithClaude_Click" />
        </StackPanel>
        <StackPanel Spacing="2"
                    IsVisible="{Binding IsOAuthPending}">
            <Grid ColumnDefinitions="*,Auto">
                <TextBox x:Name="OAuthCodeBox"
                         Grid.Column="0"
                         Watermark="Paste code from browser (code#state)"
                         FontSize="9" />
                <Button Grid.Column="1"
                        Content="Connect"
                        Padding="4,2"
                        Margin="4,0,0,0"
                        Click="ConnectOAuthCode_Click" />
            </Grid>
            <TextBlock Text="Approve the sign-in in your browser, copy the code it shows, paste it here, then click Connect."
                       FontSize="8"
                       Foreground="#FF666666"
                       TextWrapping="Wrap" />
        </StackPanel>
        <StackPanel Orientation="Horizontal"
                    Spacing="4"
                    IsVisible="{Binding ShowDisconnectOAuth}">
            <Button Content="Disconnect"
                    Classes="action-button"
                    Click="DisconnectOAuth_Click" />
        </StackPanel>
        <WrapPanel Orientation="Horizontal">
            <ToggleSwitch Content="Enable"
                          Classes="settings-toggle"
                          OnContent=""
                          OffContent=""
                          IsVisible="{Binding HasEnableToggle}"
                          IsChecked="{Binding IsEnabled}" />
            <ToggleSwitch Content="Details"
                          Classes="settings-toggle"
                          OnContent=""
                          OffContent=""
                          IsVisible="{Binding HasDetailsToggle}"
                          IsChecked="{Binding ShowDetails}" />
            <ToggleSwitch Content="Limits"
                          Classes="settings-toggle"
                          OnContent=""
                          OffContent=""
                          IsVisible="{Binding HasLimitsToggle}"
                          IsChecked="{Binding ShowLimits}" />
            <ToggleSwitch Content="Limits"
                          Classes="settings-toggle"
                          OnContent=""
                          OffContent=""
                          IsVisible="{Binding HasBreakdownToggle}"
                          IsChecked="{Binding ShowBreakdown}" />
        </WrapPanel>
        <StackPanel Spacing="2"
                    IsVisible="{Binding ShowAdvancedSection}">
            <Button Content="Advanced ▾"
                    Classes="action-button"
                    HorizontalAlignment="Left"
                    Click="AdvancedToggle_Click" />
            <StackPanel Spacing="2"
                        IsVisible="{Binding IsAdvancedExpanded}">
                <TextBlock Text="{Binding AdvancedHint}"
                           FontSize="8"
                           Foreground="#FF666666"
                           TextWrapping="Wrap"
                           MaxLines="3" />
                <Grid ColumnDefinitions="*,Auto"
                      IsVisible="{Binding ShowApiKeyField}">
                    <TextBox x:Name="ApiKeyBox"
                             Grid.Column="0"
                             Watermark="{Binding ApiKeyWatermark}"
                             PasswordChar="•"
                             FontSize="9"
                             LostFocus="ApiKeyBox_LostFocus" />
                    <Button Grid.Column="1"
                            Content="Clear"
                            FontSize="8"
                            Padding="4,2"
                            Margin="4,0,0,0"
                            IsVisible="{Binding HasApiKeySaved}"
                            Click="ClearApiKey_Click" />
                </Grid>
                <Grid ColumnDefinitions="*,Auto"
                      IsVisible="{Binding ShowManagementApiKeyField}">
                    <TextBox x:Name="ManagementApiKeyBox"
                             Grid.Column="0"
                             Watermark="{Binding ManagementApiKeyWatermark}"
                             PasswordChar="•"
                             FontSize="9"
                             LostFocus="ManagementApiKeyBox_LostFocus" />
                    <Button Grid.Column="1"
                            Content="Clear"
                            FontSize="8"
                            Padding="4,2"
                            Margin="4,0,0,0"
                            IsVisible="{Binding HasManagementApiKeySaved}"
                            Click="ClearManagementApiKey_Click" />
                </Grid>
                <Grid ColumnDefinitions="*,8,*"
                      IsVisible="{Binding ShowOrgIdField}">
                    <TextBox Grid.Column="0"
                             Watermark="Org ID (optional)"
                             FontSize="9"
                             Text="{Binding OrgId}" />
                    <TextBox Grid.Column="2"
                             Watermark="Budget USD"
                             FontSize="9"
                             Text="{Binding Budget}"
                             IsVisible="{Binding ShowBudgetField}" />
                </Grid>
                <TextBox Watermark="Budget USD"
                         FontSize="9"
                         Text="{Binding Budget}"
                         IsVisible="{Binding ShowStandaloneBudgetField}" />
                <TextBox Watermark="Workspace ID"
                         FontSize="9"
                         Text="{Binding WorkspaceId}"
                         IsVisible="{Binding ShowWorkspaceField}" />
                <Grid ColumnDefinitions="*,Auto"
                      IsVisible="{Binding ShowSessionField}">
                    <TextBox x:Name="SessionBox"
                             Grid.Column="0"
                             Watermark="{Binding SessionWatermark}"
                             PasswordChar="•"
                             FontSize="9"
                             LostFocus="SessionBox_LostFocus" />
                    <Button Grid.Column="1"
                            Content="Clear"
                            FontSize="8"
                            Padding="4,2"
                            Margin="4,0,0,0"
                            IsVisible="{Binding HasSessionSaved}"
                            Click="ClearSession_Click" />
                </Grid>
            </StackPanel>
        </StackPanel>
    </StackPanel>
</UserControl>
