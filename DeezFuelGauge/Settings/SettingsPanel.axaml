<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:settings="using:DeezFuelGauge.Settings"
             xmlns:controls="using:DeezFuelGauge.Settings.Controls"
             x:Class="DeezFuelGauge.Settings.SettingsPanel"
             x:DataType="settings:SettingsPanelViewModel"
             PointerPressed="SettingsPanel_PointerPressed">
    <UserControl.Styles>
        <StyleInclude Source="avares://DeezFuelGauge/Settings/SettingsStyles.axaml" />
    </UserControl.Styles>
    <ScrollViewer MaxHeight="300"
                  HorizontalScrollBarVisibility="Disabled">
        <ItemsControl ItemsSource="{Binding Sections}">
            <ItemsControl.ItemTemplate>
                <DataTemplate x:DataType="settings:ProviderSettingsSectionViewModel">
                    <Border Classes="provider-card"
                            Margin="0,0,0,3">
                        <StackPanel Spacing="3">
                            <Border Background="Transparent"
                                    Cursor="Hand"
                                    PointerPressed="SectionHeader_PointerPressed"
                                    Tag="{Binding ProviderId}">
                                <Grid ColumnDefinitions="Auto,*,Auto,Auto">
                                    <TextBlock Grid.Column="0"
                                               Text="●"
                                               FontSize="8"
                                               Foreground="{Binding HeaderColor}"
                                               VerticalAlignment="Center"
                                               Margin="0,0,5,0" />
                                    <StackPanel Grid.Column="1"
                                                Spacing="1">
                                        <TextBlock Text="{Binding Title}"
                                                   FontSize="10"
                                                   FontWeight="SemiBold"
                                                   Foreground="#FF00E5FF" />
                                        <TextBlock Text="{Binding SummaryStatus}"
                                                   Classes="summary-text" />
                                    </StackPanel>
                                    <ToggleSwitch Grid.Column="2"
                                                  Content="Enable"
                                                  Classes="settings-toggle"
                                                  OnContent=""
                                                  OffContent=""
                                                  IsVisible="{Binding ShowMasterEnable}"
                                                  IsChecked="{Binding MasterEnable}"
                                                  Checked="MasterEnable_Changed"
                                                  Unchecked="MasterEnable_Changed"
                                                  Tag="{Binding}"
                                                  VerticalAlignment="Center"
                                                  Margin="0,0,4,0" />
                                    <TextBlock Grid.Column="3"
                                               Text="{Binding Chevron}"
                                               FontSize="9"
                                               Foreground="#FF888888"
                                               VerticalAlignment="Center" />
                                </Grid>
                            </Border>
                            <StackPanel Spacing="4"
                                        IsVisible="{Binding IsExpanded}">
                                <ItemsControl ItemsSource="{Binding Sources}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate x:DataType="settings:ProviderSourceViewModel">
                                            <StackPanel Spacing="2">
                                                <Border Classes="subsection-divider"
                                                        IsVisible="{Binding HasEnableToggle}" />
                                                <controls:SettingsSourceRow />
                                            </StackPanel>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </StackPanel>
                    </Border>
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>
    </ScrollViewer>
</UserControl>
