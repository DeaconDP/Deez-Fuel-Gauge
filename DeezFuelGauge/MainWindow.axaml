<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="DeezFuelGauge.MainWindow"
        xmlns:settings="using:DeezFuelGauge.Settings"
        Title="Deez Fuel Gauge"
        Width="300"
        SizeToContent="Height"
        ExtendClientAreaChromeHints="NoChrome"
        ExtendClientAreaToDecorationsHint="True"
        TransparencyLevelHint="Transparent"
        Background="Transparent"
        CanResize="False"
        ShowInTaskbar="False"
        Topmost="True"
        PointerPressed="Window_PointerPressed">
    <Window.Styles>
        <Style Selector="Border.breakdown-note-host">
            <Setter Property="MaxHeight" Value="0" />
            <Setter Property="Opacity" Value="0" />
            <Setter Property="ClipToBounds" Value="True" />
            <Setter Property="Transitions">
                <Transitions>
                    <DoubleTransition Property="Opacity" Duration="0:0:0.15" Easing="CubicEaseOut" />
                    <DoubleTransition Property="MaxHeight" Duration="0:0:0.22" Easing="CubicEaseOut" />
                </Transitions>
            </Setter>
        </Style>
        <Style Selector="Border.breakdown-row:pointerover Border.breakdown-note-host">
            <Setter Property="MaxHeight" Value="56" />
            <Setter Property="Opacity" Value="1" />
        </Style>
        <Style Selector="Border.header-icon-button">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Width" Value="18" />
            <Setter Property="Height" Value="18" />
            <Setter Property="Margin" Value="6,0,0,0" />
        </Style>
        <Style Selector="Border.header-icon-button > Viewbox">
            <Setter Property="Width" Value="12" />
            <Setter Property="Height" Value="12" />
            <Setter Property="Stretch" Value="Uniform" />
            <Setter Property="HorizontalAlignment" Value="Center" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>
        <Style Selector="Border.header-icon-button TextBlock">
            <Setter Property="FontFamily" Value="Segoe UI Symbol, Apple Symbols, sans-serif" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="TextAlignment" Value="Center" />
            <Setter Property="HorizontalAlignment" Value="Center" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>
        <Style Selector="Border.settings-panel-host">
            <Setter Property="MaxHeight" Value="0" />
            <Setter Property="Opacity" Value="0" />
            <Setter Property="Margin" Value="0" />
            <Setter Property="ClipToBounds" Value="True" />
            <Setter Property="IsHitTestVisible" Value="False" />
            <Setter Property="RenderTransformOrigin" Value="50%,100%" />
            <Setter Property="RenderTransform" Value="translateY(18px)" />
            <Setter Property="Transitions">
                <Transitions>
                    <DoubleTransition Property="Opacity" Duration="0:0:0.2" Easing="CubicEaseOut" />
                    <DoubleTransition Property="MaxHeight" Duration="0:0:0.26" Easing="CubicEaseOut" />
                    <TransformOperationsTransition Property="RenderTransform" Duration="0:0:0.26" Easing="CubicEaseOut" />
                </Transitions>
            </Setter>
        </Style>
        <Style Selector="Border.settings-panel-host.expanded">
            <Setter Property="MaxHeight" Value="400" />
            <Setter Property="Opacity" Value="1" />
            <Setter Property="Margin" Value="0,0,0,8" />
            <Setter Property="IsHitTestVisible" Value="True" />
            <Setter Property="RenderTransform" Value="translateY(0)" />
        </Style>
    </Window.Styles>
    <Border x:Name="PillBorder"
            CornerRadius="10"
            Background="#E6181818"
            BorderBrush="#44FFFFFF"
            BorderThickness="1"
            Padding="10,9,10,12">
        <Border.ContextMenu>
            <ContextMenu>
                <MenuItem Header="Refresh" Click="RefreshMenuItem_Click" />
                <Separator />
                <MenuItem Header="Quit" Click="QuitMenuItem_Click" />
            </ContextMenu>
        </Border.ContextMenu>
        <StackPanel>
            <Grid Margin="0,0,0,6">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0" Orientation="Horizontal">
                    <Image Source="avares://DeezFuelGauge/Assets/app-icon.png"
                           Width="18"
                           Height="18"
                           Margin="0,0,7,0"
                           VerticalAlignment="Center" />
                    <TextBlock Text="Deez Fuel Gauge"
                               FontFamily="Segoe UI Semibold, Segoe UI, sans-serif"
                               FontSize="13"
                               FontWeight="SemiBold"
                               LineHeight="18"
                               Foreground="#FF00E5FF"
                               VerticalAlignment="Center" />
                </StackPanel>
                <StackPanel Grid.Column="1"
                            Orientation="Horizontal"
                            VerticalAlignment="Center">
                    <Border Classes="header-icon-button"
                            Margin="0"
                            ToolTip.Tip="Refresh"
                            PointerPressed="RefreshButton_PointerPressed">
                        <Viewbox>
                            <TextBlock Text="&#x21BB;"
                                       Foreground="#FF00E5FF" />
                        </Viewbox>
                    </Border>
                    <Border x:Name="SettingsButton"
                            Classes="header-icon-button"
                            ToolTip.Tip="Settings"
                            PointerPressed="SettingsToggle_PointerPressed">
                        <Viewbox>
                            <TextBlock x:Name="SettingsIcon"
                                       Text="&#x2699;"
                                       Foreground="#FF44CC44" />
                        </Viewbox>
                    </Border>
                    <Border Classes="header-icon-button"
                            ToolTip.Tip="Pin"
                            PointerPressed="PinToggle_PointerPressed">
                        <Viewbox>
                            <TextBlock x:Name="PinIcon"
                                       Text="&#x2316;"
                                       Foreground="#FFFFCC00" />
                        </Viewbox>
                    </Border>
                    <Border Classes="header-icon-button"
                            ToolTip.Tip="Close"
                            PointerPressed="CloseButton_PointerPressed">
                        <Viewbox>
                            <TextBlock Text="&#x2715;"
                                       Foreground="#FFFF4444" />
                        </Viewbox>
                    </Border>
                </StackPanel>
            </Grid>
            <TextBlock x:Name="QuotaAlertHeaderText"
                       Text=""
                       FontSize="9"
                       LineHeight="12"
                       Foreground="#FFE5A000"
                       Margin="0,-2,0,4"
                       IsVisible="False" />
            <Border x:Name="SettingsPanelHost"
                    Classes="settings-panel-host"
                    Padding="0"
                    CornerRadius="6"
                    Background="Transparent"
                    HorizontalAlignment="Stretch">
                <settings:SettingsPanel x:Name="SettingsPanelControl" />
            </Border>
            <StackPanel x:Name="CursorProviderSection">
                <Border x:Name="CursorProviderHeader"
                        Background="Transparent"
                        Cursor="Hand"
                        Margin="0,0,0,4"
                        PointerPressed="CursorProvider_PointerPressed">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <TextBlock x:Name="CursorProviderLabel"
                                   Text="Cursor"
                                   Grid.Column="0"
                                   VerticalAlignment="Center"
                                   Margin="0,0,8,0"
                                   FontFamily="Segoe UI Semibold, Segoe UI, sans-serif"
                                   FontSize="11"
                                   FontWeight="SemiBold"
                                   Foreground="#FFB0B0B0" />
                        <Grid x:Name="CursorHeadlineTrack"
                              Grid.Column="1"
                              Height="6"
                              VerticalAlignment="Center">
                            <Border CornerRadius="3" Background="#33FFFFFF" />
                            <Border x:Name="CursorHeadlineFill"
                                    CornerRadius="3"
                                    HorizontalAlignment="Left"
                                    Width="0"
                                    Background="#FF4CAF50" />
                        </Grid>
                    </Grid>
                </Border>
                <StackPanel x:Name="CursorDetailsPanel" IsVisible="False">
            <StackPanel x:Name="CursorSection">
                <Border x:Name="BreakdownPanel"
                        Padding="6,5"
                        CornerRadius="5"
                        Background="#FF252525"
                        IsVisible="False">
                    <StackPanel Spacing="5">
                        <Border Classes="breakdown-row" Background="Transparent">
                            <StackPanel>
                                <Grid Margin="0,0,0,2">
                                    <TextBlock Text="Auto + Composer"
                                               FontSize="9.5"
                                               LineHeight="12"
                                               Foreground="#FFE8E8E8"
                                               HorizontalAlignment="Left" />
                                    <TextBlock x:Name="AutoPercentText"
                                               Text=""
                                               FontSize="9.5"
                                               LineHeight="12"
                                               Foreground="#FFE8E8E8"
                                               HorizontalAlignment="Right" />
                                </Grid>
                                <Grid x:Name="AutoProgressTrack" Height="4">
                                    <Border CornerRadius="2" Background="#33FFFFFF" />
                                    <Border x:Name="AutoProgressFill"
                                            CornerRadius="2"
                                            HorizontalAlignment="Left"
                                            Width="0"
                                            Background="#FF4D9FFF" />
                                </Grid>
                                <Border Classes="breakdown-note-host">
                                    <TextBlock Classes="breakdown-note"
                                               Text="Additional usage beyond limits consumes API quota or on-demand spend."
                                               FontSize="8"
                                               LineHeight="11"
                                               Foreground="#FF666666"
                                               TextWrapping="Wrap"
                                               Margin="0,2,0,0" />
                                </Border>
                            </StackPanel>
                        </Border>
                        <Border Classes="breakdown-row" Background="Transparent">
                            <StackPanel>
                                <Grid Margin="0,0,0,2">
                                    <TextBlock Text="API"
                                               FontSize="9.5"
                                               LineHeight="12"
                                               Foreground="#FFE8E8E8"
                                               HorizontalAlignment="Left" />
                                    <TextBlock x:Name="ApiPercentText"
                                               Text=""
                                               FontSize="9.5"
                                               LineHeight="12"
                                               Foreground="#FFE8E8E8"
                                               HorizontalAlignment="Right" />
                                </Grid>
                                <Grid x:Name="ApiProgressTrack" Height="4">
                                    <Border CornerRadius="2" Background="#33FFFFFF" />
                                    <Border x:Name="ApiProgressFill"
                                            CornerRadius="2"
                                            HorizontalAlignment="Left"
                                            Width="0"
                                            Background="#FF4D9FFF" />
                                </Grid>
                                <Border Classes="breakdown-note-host">
                                    <TextBlock x:Name="ApiPlanNoteText"
                                               Classes="breakdown-note"
                                               Text=""
                                               FontSize="8"
                                               LineHeight="11"
                                               Foreground="#FF666666"
                                               TextWrapping="Wrap"
                                               Margin="0,2,0,0" />
                                </Border>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Border>
                <TextBlock x:Name="RemainingText"
                           Text=""
                           FontSize="10"
                           LineHeight="13"
                           Foreground="#FFB0B0B0"
                           Margin="0,2,0,0" />
            </StackPanel>
                </StackPanel>
            </StackPanel>
            <StackPanel x:Name="OpenAiProviderSection">
                <Border x:Name="OpenAiProviderHeader"
                        Background="Transparent"
                        Cursor="Hand"
                        Margin="0,0,0,4"
                        PointerPressed="OpenAiProvider_PointerPressed">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <TextBlock x:Name="OpenAiProviderLabel"
                                   Text="OpenAI"
                                   Grid.Column="0"
                                   VerticalAlignment="Center"
                                   Margin="0,0,8,0"
                                   FontFamily="Segoe UI Semibold, Segoe UI, sans-serif"
                                   FontSize="11"
                                   FontWeight="SemiBold"
                                   Foreground="#FFB0B0B0" />
                        <Grid x:Name="OpenAiHeadlineTrack"
                              Grid.Column="1"
                              Height="6"
                              VerticalAlignment="Center">
                            <Border CornerRadius="3" Background="#33FFFFFF" />
                            <Border x:Name="OpenAiHeadlineFill"
                                    CornerRadius="3"
                                    HorizontalAlignment="Left"
                                    Width="0"
                                    Background="#FF4CAF50" />
                        </Grid>
                    </Grid>
                </Border>
                <StackPanel x:Name="OpenAiDetailsPanel" IsVisible="False">
            <Grid x:Name="OpenAiSection" Margin="0,0,0,4">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <TextBlock Text="OpenAI (Cursor)"
                           Grid.Column="0"
                           VerticalAlignment="Center"
                           Margin="0,0,8,0"
                           FontFamily="Segoe UI Semibold, Segoe UI, sans-serif"
                           FontSize="11"
                           FontWeight="SemiBold"
                           Foreground="#FFB0B0B0" />
                <Grid x:Name="OpenAiProgressTrack"
                      Grid.Column="1"
                      Height="6"
                      VerticalAlignment="Center">
                    <Border CornerRadius="3" Background="#33FFFFFF" />
                    <Border x:Name="OpenAiProgressFill"
                            CornerRadius="3"
                            HorizontalAlignment="Left"
                            Width="0"
                            Background="#FF4CAF50" />
                </Grid>
            </Grid>
            <TextBlock x:Name="OpenAiDetailText"
                       Margin="0,2,0,4"
                       FontSize="9"
                       LineHeight="12"
                       Foreground="#FF777777"
                       IsVisible="False" />
            <Grid x:Name="OpenAiDirectSection" Margin="0,0,0,4">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <TextBlock Text="OpenAI (direct)"
                           Grid.Column="0"
                           VerticalAlignment="Center"
                           Margin="0,0,8,0"
                           FontFamily="Segoe UI Semibold, Segoe UI, sans-serif"
                           FontSize="11"
                           FontWeight="SemiBold"
                           Foreground="#FFB0B0B0" />
                <Grid x:Name="OpenAiDirectProgressTrack"
                      Grid.Column="1"
                      Height="6"
                      VerticalAlignment="Center">
                    <Border CornerRadius="3" Background="#33FFFFFF" />
                    <Border x:Name="OpenAiDirectProgressFill"
                            CornerRadius="3"
                            HorizontalAlignment="Left"
                            Width="0"
                            Background="#FF4CAF50" />
                </Grid>
            </Grid>
            <TextBlock x:Name="OpenAiDirectDetailText"
                       Margin="0,2,0,4"
                       FontSize="9"
                       LineHeight="12"
                       Foreground="#FF777777"
                       IsVisible="False" />
            <StackPanel x:Name="CodexLimitsSection" IsVisible="False">
                <TextBlock x:Name="CodexPercentText"
                           Text="..."
                           FontSize="12"
                           FontWeight="SemiBold"
                           LineHeight="16"
                           Foreground="#FFE8E8E8" />
                <Border x:Name="CodexBarBorder"
                        Background="Transparent"
                        PointerPressed="CodexLimits_PointerPressed">
                    <Grid Margin="0,5,0,5">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Codex"
                                   Grid.Column="0"
                                   VerticalAlignment="Center"
                                   Margin="0,0,8,0"
                                   FontFamily="Segoe UI Semibold, Segoe UI, sans-serif"
                                   FontSize="11"
                                   FontWeight="SemiBold"
                                   Foreground="#FFB0B0B0" />
                        <Grid x:Name="CodexProgressTrack"
                              Grid.Column="1"
                              Height="6"
                              VerticalAlignment="Center">
                            <Border CornerRadius="3" Background="#33FFFFFF" />
                            <Border x:Name="CodexProgressFill"
                                    CornerRadius="3"
                                    HorizontalAlignment="Left"
                                    Width="0"
                                    Background="#FF4CAF50" />
                        </Grid>
                    </Grid>
                </Border>
                <StackPanel x:Name="CodexBreakdownSection"
                            Margin="0,3,0,0"
                            IsVisible="False">
                    <StackPanel Orientation="Horizontal"
                                Spacing="4">
                        <TextBlock x:Name="CodexBreakdownChevron"
                                   Text="&#x25BE;"
                                   FontSize="10"
                                   LineHeight="14"
                                   Foreground="#FF888888"
                                   VerticalAlignment="Center" />
                        <TextBlock x:Name="CodexBreakdownSummary"
                                   Text=""
                                   FontSize="10"
                                   LineHeight="14"
                                   Foreground="#FF888888"
                                   VerticalAlignment="Center"
                                   TextWrapping="Wrap" />
                    </StackPanel>
                    <Border x:Name="CodexBreakdownPanel"
                            Margin="0,6,0,0"
                            Padding="8,7"
                            CornerRadius="6"
                            Background="#FF121212"
                            IsVisible="False">
                        <StackPanel Spacing="10">
                            <StackPanel>
                                <Grid Margin="0,0,0,4">
                                    <TextBlock Text="5h"
                                               FontSize="10"
                                               LineHeight="13"
                                               Foreground="#FFE8E8E8"
                                               HorizontalAlignment="Left" />
                                    <TextBlock x:Name="CodexSessionPercentText"
                                               Text=""
                                               FontSize="10"
                                               LineHeight="13"
                                               Foreground="#FFE8E8E8"
                                               HorizontalAlignment="Right" />
                                </Grid>
                                <Grid x:Name="CodexSessionProgressTrack" Height="5">
                                    <Border CornerRadius="2.5" Background="#33FFFFFF" />
                                    <Border x:Name="CodexSessionProgressFill"
                                            CornerRadius="2.5"
                                            HorizontalAlignment="Left"
                                            Width="0"
                                            Background="#FF4CAF50" />
                                </Grid>
                                <TextBlock Text="Rolling 5-hour usage window."
                                           FontSize="8.5"
                                           LineHeight="12"
                                           Foreground="#FF666666"
                                           TextWrapping="Wrap"
                                           Margin="0,4,0,0" />
                            </StackPanel>
                            <StackPanel>
                                <Grid Margin="0,0,0,4">
                                    <TextBlock Text="Weekly"
                                               FontSize="10"
                                               LineHeight="13"
                                               Foreground="#FFE8E8E8"
                                               HorizontalAlignment="Left" />
                                    <TextBlock x:Name="CodexWeeklyPercentText"
                                               Text=""
                                               FontSize="10"
                                               LineHeight="13"
                                               Foreground="#FFE8E8E8"
                                               HorizontalAlignment="Right" />
                                </Grid>
                                <Grid x:Name="CodexWeeklyProgressTrack" Height="5">
                                    <Border CornerRadius="2.5" Background="#33FFFFFF" />
                                    <Border x:Name="CodexWeeklyProgressFill"
                                            CornerRadius="2.5"
                                            HorizontalAlignment="Left"
                                            Width="0"
                                            Background="#FF4CAF50" />
                                </Grid>
                                <TextBlock Text="Rolling 7-day usage window."
                                           FontSize="8.5"
                                           LineHeight="12"
                                           Foreground="#FF666666"
                                           TextWrapping="Wrap"
                                           Margin="0,4,0,0" />
                            </StackPanel>
                        </StackPanel>
                    </Border>
                </StackPanel>
                <TextBlock x:Name="CodexRemainingText"
                           Text=""
                           FontSize="11"
                           LineHeight="15"
                           Foreground="#FFB0B0B0" />
            </StackPanel>
                </StackPanel>
            </StackPanel>
            <StackPanel x:Name="ClaudeProviderSection">
                <Border x:Name="ClaudeProviderHeader"
                        Background="Transparent"
                        Cursor="Hand"
                        Margin="0,0,0,4"
                        PointerPressed="ClaudeProvider_PointerPressed">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <TextBlock x:Name="ClaudeProviderLabel"
                                   Text="Claude"
                                   Grid.Column="0"
                                   VerticalAlignment="Center"
                                   Margin="0,0,8,0"
                                   FontFamily="Segoe UI Semibold, Segoe UI, sans-serif"
                                   FontSize="11"
                                   FontWeight="SemiBold"
                                   Foreground="#FFB0B0B0" />
                        <Grid x:Name="ClaudeHeadlineTrack"
                              Grid.Column="1"
                              Height="6"
                              VerticalAlignment="Center">
                            <Border CornerRadius="3" Background="#33FFFFFF" />
                            <Border x:Name="ClaudeHeadlineFill"
                                    CornerRadius="3"
                                    HorizontalAlignment="Left"
                                    Width="0"
                                    Background="#FF4CAF50" />
                        </Grid>
                    </Grid>
                </Border>
                <StackPanel x:Name="ClaudeDetailsPanel" IsVisible="False">
            <Grid x:Name="ClaudeSection" Margin="0,0,0,4">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <TextBlock Text="Claude (Cursor)"
                           Grid.Column="0"
                           VerticalAlignment="Center"
                           Margin="0,0,8,0"
                           FontFamily="Segoe UI Semibold, Segoe UI, sans-serif"
                           FontSize="11"
                           FontWeight="SemiBold"
                           Foreground="#FFB0B0B0" />
                <Grid x:Name="ClaudeProgressTrack"
                      Grid.Column="1"
                      Height="6"
                      VerticalAlignment="Center">
                    <Border CornerRadius="3" Background="#33FFFFFF" />
                    <Border x:Name="ClaudeProgressFill"
                            CornerRadius="3"
                            HorizontalAlignment="Left"
                            Width="0"
                            Background="#FF4CAF50" />
                </Grid>
            </Grid>
            <TextBlock x:Name="ClaudeDetailText"
                       Margin="0,2,0,4"
                       FontSize="9"
                       LineHeight="12"
                       Foreground="#FF777777"
                       IsVisible="False" />
            <StackPanel x:Name="ClaudeProLimitsSection" IsVisible="False">
                <TextBlock x:Name="ClaudeProPercentText"
                           Text="..."
                           FontSize="12"
                           FontWeight="SemiBold"
                           LineHeight="16"
                           Foreground="#FFE8E8E8" />
                <Border x:Name="ClaudeProBarBorder"
                        Background="Transparent"
                        PointerPressed="ClaudeProLimits_PointerPressed">
                    <Grid Margin="0,5,0,5">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Plan usage"
                                   Grid.Column="0"
                                   VerticalAlignment="Center"
                                   Margin="0,0,8,0"
                                   FontFamily="Segoe UI Semibold, Segoe UI, sans-serif"
                                   FontSize="11"
                                   FontWeight="SemiBold"
                                   Foreground="#FFB0B0B0" />
                        <Grid x:Name="ClaudeProProgressTrack"
                              Grid.Column="1"
                              Height="6"
                              VerticalAlignment="Center">
                            <Border CornerRadius="3" Background="#33FFFFFF" />
                            <Border x:Name="ClaudeProProgressFill"
                                    CornerRadius="3"
                                    HorizontalAlignment="Left"
                                    Width="0"
                                    Background="#FF4CAF50" />
                        </Grid>
                    </Grid>
                </Border>
                <StackPanel x:Name="ClaudeProBreakdownSection"
                            Margin="0,3,0,0"
                            IsVisible="False">
                    <StackPanel Orientation="Horizontal"
                                Spacing="4">
                        <TextBlock x:Name="ClaudeProBreakdownChevron"
                                   Text="&#x25BE;"
                                   FontSize="10"
                                   LineHeight="14"
                                   Foreground="#FF888888"
                                   VerticalAlignment="Center" />
                        <TextBlock x:Name="ClaudeProBreakdownSummary"
                                   Text=""
                                   FontSize="10"
                                   LineHeight="14"
                                   Foreground="#FF888888"
                                   VerticalAlignment="Center"
                                   TextWrapping="Wrap" />
                    </StackPanel>
                    <Border x:Name="ClaudeProBreakdownPanel"
                            Margin="0,6,0,0"
                            Padding="8,7"
                            CornerRadius="6"
                            Background="#FF121212"
                            IsVisible="False">
                        <StackPanel Spacing="10">
                            <StackPanel>
                                <Grid Margin="0,0,0,4">
                                    <TextBlock Text="5-hour limit"
                                               FontSize="10"
                                               LineHeight="13"
                                               Foreground="#FFE8E8E8"
                                               HorizontalAlignment="Left" />
                                    <TextBlock x:Name="ClaudeProSessionPercentText"
                                               Text=""
                                               FontSize="10"
                                               LineHeight="13"
                                               Foreground="#FFE8E8E8"
                                               HorizontalAlignment="Right" />
                                </Grid>
                                <Grid x:Name="ClaudeProSessionProgressTrack" Height="5">
                                    <Border CornerRadius="2.5" Background="#33FFFFFF" />
                                    <Border x:Name="ClaudeProSessionProgressFill"
                                            CornerRadius="2.5"
                                            HorizontalAlignment="Left"
                                            Width="0"
                                            Background="#FF4CAF50" />
                                </Grid>
                                <TextBlock Text="Rolling 5-hour usage window."
                                           FontSize="8.5"
                                           LineHeight="12"
                                           Foreground="#FF666666"
                                           TextWrapping="Wrap"
                                           Margin="0,4,0,0" />
                            </StackPanel>
                            <StackPanel>
                                <Grid Margin="0,0,0,4">
                                    <TextBlock Text="Weekly · All models"
                                               FontSize="10"
                                               LineHeight="13"
                                               Foreground="#FFE8E8E8"
                                               HorizontalAlignment="Left" />
                                    <TextBlock x:Name="ClaudeProWeeklyPercentText"
                                               Text=""
                                               FontSize="10"
                                               LineHeight="13"
                                               Foreground="#FFE8E8E8"
                                               HorizontalAlignment="Right" />
                                </Grid>
                                <Grid x:Name="ClaudeProWeeklyProgressTrack" Height="5">
                                    <Border CornerRadius="2.5" Background="#33FFFFFF" />
                                    <Border x:Name="ClaudeProWeeklyProgressFill"
                                            CornerRadius="2.5"
                                            HorizontalAlignment="Left"
                                            Width="0"
                                            Background="#FF4CAF50" />
                                </Grid>
                                <TextBlock Text="Rolling 7-day usage window."
                                           FontSize="8.5"
                                           LineHeight="12"
                                           Foreground="#FF666666"
                                           TextWrapping="Wrap"
