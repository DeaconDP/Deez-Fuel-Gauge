            <StackPanel x:Name="DiskSection"
                        Margin="0,6,0,0"
                        Spacing="4"
                        IsVisible="False" />
            <Grid Margin="0,6,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBlock x:Name="LastRefreshedText"
                           Grid.Column="0"
                           FontSize="8"
                           LineHeight="11"
                           Foreground="#44FFFFFF"
                           HorizontalAlignment="Left"
                           VerticalAlignment="Center"
                           IsVisible="False" />
                <StackPanel Grid.Column="1"
                            Orientation="Horizontal"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Center"
                            Spacing="0">
                    <TextBlock Text="built by "
                               FontSize="8.5"
                               LineHeight="12"
                               Foreground="#44FFFFFF"
                               VerticalAlignment="Center" />
                    <TextBlock Text="deac.online"
                               FontSize="8.5"
                               LineHeight="12"
                               Foreground="#55AAAAAA"
                               Cursor="Hand"
                               VerticalAlignment="Center"
                               PointerPressed="DeacLink_PointerPressed" />
                    <TextBlock Text=" @ "
                               FontSize="8.5"
                               LineHeight="12"
                               Foreground="#44FFFFFF"
                               VerticalAlignment="Center" />
                    <TextBlock Text="worldbuild.io"
                               FontSize="8.5"
                               LineHeight="12"
                               Foreground="#55AAAAAA"
                               Cursor="Hand"
                               VerticalAlignment="Center"
                               PointerPressed="WorldbuildLink_PointerPressed" />
                </StackPanel>
            </Grid>
        </StackPanel>
    </Border>
