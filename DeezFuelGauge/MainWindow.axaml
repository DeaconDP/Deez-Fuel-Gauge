<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="DeezFuelGauge.MainWindow"
        xmlns:settings="using:DeezFuelGauge.Settings"
        Title="Cursor Usage"
        Width="300"
        SizeToContent="Height"
        ExtendClientAreaChromeHints="NoChrome"
        ExtendClientAreaToDecorationsHint="True"
        TransparencyLevelHint="Transparent"
        Background="Transparent"
        CanResize="False"
        ShowInTaskbar="False"
        Topmost="True"
        PointerPressed="Window_PointerPressed">
    <Border x:Name="PillBorder"
            CornerRadius="10"
            Background="#E6181818"
            BorderBrush="#44FFFFFF"
            BorderThickness="1"
            Padding="10,9,10,12">
        <Border.ContextMenu>
            <ContextMenu>
                <MenuItem Header="Refresh" Click="RefreshMenuItem_Click" />
                <Separator />
                <MenuItem Header="Quit" Click="QuitMenuItem_Click" />
            </ContextMenu>
        </Border.ContextMenu>
        <StackPanel>
            <Grid Margin="0,0,0,6">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0" Orientation="Horizontal">
                    <TextBlock Text="&#x1F701;"
                               FontSize="15"
                               LineHeight="18"
                               Foreground="#CC00E5FF"
                               Margin="0,0,7,0"
                               VerticalAlignment="Center" />
                    <TextBlock Text="Deez Fuel Guage"
                               FontFamily="Segoe UI Semibold, Segoe UI, sans-serif"
                               FontSize="13"
                               FontWeight="SemiBold"
                               LineHeight="18"
                               Foreground="#FF00E5FF"
                               VerticalAlignment="Center" />
                </StackPanel>
                <StackPanel Grid.Column="1"
                            Orientation="Horizontal"
                            VerticalAlignment="Center">
                    <Border Background="Transparent"
                            Cursor="Hand"
                            Padding="2,0,0,0"
                            ToolTip.Tip="Settings"
                            PointerPressed="SettingsToggle_PointerPressed">
                        <TextBlock x:Name="SettingsIcon"
                                   Text="&#x2699;"
                                   FontFamily="Segoe UI Symbol, Apple Symbols, sans-serif"
                                   FontSize="14"
                                   LineHeight="18"
                                   Foreground="#FF44CC44"
                                   VerticalAlignment="Center" />
                    </Border>
                    <Border Background="Transparent"
                            Cursor="Hand"
                            Margin="6,0,0,0"
                            ToolTip.Tip="Refresh"
                            PointerPressed="RefreshButton_PointerPressed">
                        <TextBlock x:Name="RefreshIcon"
                                   Text="&#x21BB;"
                                   FontFamily="Segoe UI Symbol, Apple Symbols, sans-serif"
                                   FontSize="14"
                                   LineHeight="18"
                                   Foreground="#FF88CCFF"
                                   VerticalAlignment="Center" />
                    </Border>
                    <Border x:Name="PinButton"
                            Background="Transparent"
                            Cursor="Hand"
                            Margin="6,0,0,0"
                            PointerPressed="PinToggle_PointerPressed">
                        <TextBlock x:Name="PinIcon"
                                   Text="&#x2316;"
                                   FontFamily="Segoe UI Symbol, Apple Symbols, sans-serif"
                                   FontSize="14"
                                   LineHeight="18"
                                   Foreground="#FFFFCC00"
                                   VerticalAlignment="Center" />
                    </Border>
                    <Border Background="Transparent"
                            Cursor="Hand"
                            Margin="6,0,0,0"
                            ToolTip.Tip="Close"
                            PointerPressed="CloseButton_PointerPressed">
                        <TextBlock Text="&#x2715;"
                                   FontFamily="Segoe UI Symbol, Apple Symbols, sans-serif"
                                   FontSize="14"
                                   LineHeight="18"
                                   Foreground="#FFFF4444"
                                   VerticalAlignment="Center" />
                    </Border>
                </StackPanel>
            </Grid>
            <Border x:Name="SettingsPanelHost"
                    Margin="0,0,0,8"
                    Padding="0"
                    CornerRadius="6"
                    Background="Transparent"
                    HorizontalAlignment="Stretch"
                    IsVisible="False">
                <settings:SettingsPanel x:Name="SettingsPanelControl" />
            </Border>
            <StackPanel x:Name="CursorProviderSection">
                <Border x:Name="CursorProviderHeader"
                        Background="Transparent"
                        Cursor="Hand"
                        Margin="0,0,0,4"
                        PointerPressed="CursorProvider_PointerPressed">
                    <StackPanel Spacing="2">
                        <TextBlock Text="Cursor"
                                   FontFamily="Segoe UI Semibold, Segoe UI, sans-serif"
                                   FontSize="11"
                                   FontWeight="SemiBold"
                                   Foreground="#FFB0B0B0" />
                        <Grid x:Name="CursorHeadlineTrack"
                              Height="6">
                            <Border CornerRadius="3" Background="#33FFFFFF" />
                            <Border x:Name="CursorHeadlineFill"
                                    CornerRadius="3"
                                    HorizontalAlignment="Left"
                                    Width="0"
                                    Background="#FF4CAF50" />
                        </Grid>
                    </StackPanel>
                </Border>
                <StackPanel x:Name="CursorDetailsPanel" IsVisible="False">
            <StackPanel x:Name="CursorSection">
                <TextBlock x:Name="PercentText"
                           Text="..."
                           FontSize="11"
                           FontWeight="SemiBold"
                           LineHeight="15"
                           Foreground="#FFE8E8E8" />
                <Border x:Name="CursorBarBorder"
                        Background="Transparent">
                    <StackPanel Margin="0,5,0,5" Spacing="2">
                        <TextBlock Text="Cursor"
                                   FontFamily="Segoe UI Semibold, Segoe UI, sans-serif"
                                   FontSize="11"
                                   FontWeight="SemiBold"
                                   Foreground="#FFB0B0B0" />
                        <Grid x:Name="ProgressTrack"
                              Height="6">
                            <Border CornerRadius="3" Background="#33FFFFFF" />
                            <Border x:Name="ProgressFill"
                                    CornerRadius="3"
                                    HorizontalAlignment="Left"
                                    Width="0"
                                    Background="#FF4CAF50" />
                        </Grid>
                    </StackPanel>
                </Border>
                <Border x:Name="BreakdownPanel"
                        Margin="0,3,0,0"
                        Padding="6,5"
                        CornerRadius="5"
                        Background="#FF252525"
                        IsVisible="False">
                    <StackPanel Spacing="5">
                        <Border x:Name="AutoBreakdownRow"
                                Classes="breakdown-row"
                                Background="Transparent">
                            <StackPanel>
                                <Grid Margin="0,0,0,2">
                                    <TextBlock Text="Auto + Composer"
                                               FontSize="11"
                                               FontWeight="SemiBold"
                                               LineHeight="15"
                                               Foreground="#FFE8E8E8"
                                               HorizontalAlignment="Left" />
                                    <TextBlock x:Name="AutoPercentText"
                                               Text=""
                                               FontSize="11"
                                               FontWeight="SemiBold"
                                               LineHeight="15"
                                               Foreground="#FFE8E8E8"
                                               HorizontalAlignment="Right" />
                                </Grid>
                                <Grid x:Name="AutoProgressTrack" Height="6">
                                    <Border CornerRadius="3" Background="#33FFFFFF" />
                                    <Border x:Name="AutoProgressFill"
                                            CornerRadius="3"
                                            HorizontalAlignment="Left"
                                            Width="0"
                                            Background="#FF4D9FFF" />
                                </Grid>
                            </StackPanel>
                        </Border>
                        <Border x:Name="ApiBreakdownRow"
                                Classes="breakdown-row"
                                Background="Transparent">
                            <StackPanel>
                                <Grid Margin="0,0,0,2">
                                    <TextBlock Text="API"
                                               FontSize="11"
                                               FontWeight="SemiBold"
                                               LineHeight="15"
                                               Foreground="#FFE8E8E8"
                                               HorizontalAlignment="Left" />
                                    <TextBlock x:Name="ApiPercentText"
                                               Text=""
                                               FontSize="11"
                                               FontWeight="SemiBold"
                                               LineHeight="15"
                                               Foreground="#FFE8E8E8"
                                               HorizontalAlignment="Right" />
                                </Grid>
                                <Grid x:Name="ApiProgressTrack" Height="6">
                                    <Border CornerRadius="3" Background="#33FFFFFF" />
                                    <Border x:Name="ApiProgressFill"
                                            CornerRadius="3"
                                            HorizontalAlignment="Left"
                                            Width="0"
                                            Background="#FF4D9FFF" />
                                </Grid>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Border>
                <TextBlock x:Name="RemainingText"
                           Text=""
                           FontSize="11"
                           LineHeight="15"
                           Foreground="#FFB0B0B0" />
            </StackPanel>
            <StackPanel x:Name="OpenAiSection" Margin="0,8,0,4" Spacing="2">
                <TextBlock Text="OpenAI"
                           FontFamily="Segoe UI Semibold, Segoe UI, sans-serif"
                           FontSize="11"
                           FontWeight="SemiBold"
                           Foreground="#FFB0B0B0" />
                <Grid x:Name="OpenAiProgressTrack"
                      Height="6">
                    <Border CornerRadius="3" Background="#33FFFFFF" />
                    <Border x:Name="OpenAiProgressFill"
                            CornerRadius="3"
                            HorizontalAlignment="Left"
                            Width="0"
                            Background="#FF4CAF50" />
                </Grid>
            </StackPanel>
            <TextBlock x:Name="OpenAiDetailText"
                       Margin="0,2,0,4"
                       FontSize="9"
                       LineHeight="12"
                       Foreground="#FF777777"
                       IsVisible="False" />
            <StackPanel x:Name="ClaudeSection" Margin="0,0,0,4" Spacing="2">
                <TextBlock Text="Claude"
                           FontFamily="Segoe UI Semibold, Segoe UI, sans-serif"
                           FontSize="11"
                           FontWeight="SemiBold"
                           Foreground="#FFB0B0B0" />
                <Grid x:Name="ClaudeProgressTrack"
                      Height="6">
                    <Border CornerRadius="3" Background="#33FFFFFF" />
                    <Border x:Name="ClaudeProgressFill"
                            CornerRadius="3"
                            HorizontalAlignment="Left"
                            Width="0"
                            Background="#FF4CAF50" />
                </Grid>
            </StackPanel>
            <TextBlock x:Name="ClaudeDetailText"
                       Margin="0,2,0,4"
                       FontSize="9"
                       LineHeight="12"
                       Foreground="#FF777777"
                       IsVisible="False" />
            <StackPanel x:Name="GeminiSection" Margin="0,0,0,4" Spacing="2">
                <TextBlock Text="Gemini"
                           FontFamily="Segoe UI Semibold, Segoe UI, sans-serif"
                           FontSize="11"
                           FontWeight="SemiBold"
                           Foreground="#FFB0B0B0" />
                <Grid x:Name="GeminiProgressTrack"
                      Height="6">
                    <Border CornerRadius="3" Background="#33FFFFFF" />
                    <Border x:Name="GeminiProgressFill"
                            CornerRadius="3"
                            HorizontalAlignment="Left"
                            Width="0"
                            Background="#FF4CAF50" />
                </Grid>
            </StackPanel>
            <TextBlock x:Name="GeminiDetailText"
                       Margin="0,2,0,0"
                       FontSize="9"
                       LineHeight="12"
                       Foreground="#FF777777"
                       IsVisible="False" />
                </StackPanel>
            </StackPanel>
            <StackPanel x:Name="OpenAiProviderSection">
                <Border x:Name="OpenAiProviderHeader"
                        Background="Transparent"
                        Cursor="Hand"
                        Margin="0,0,0,4"
                        PointerPressed="OpenAiProvider_PointerPressed">
                    <StackPanel Spacing="2">
                        <TextBlock Text="OpenAI"
                                   FontFamily="Segoe UI Semibold, Segoe UI, sans-serif"
                                   FontSize="11"
                                   FontWeight="SemiBold"
                                   Foreground="#FFB0B0B0" />
                        <Grid x:Name="OpenAiHeadlineTrack"
                              Height="6">
                            <Border CornerRadius="3" Background="#33FFFFFF" />
                            <Border x:Name="OpenAiHeadlineFill"
                                    CornerRadius="3"
                                    HorizontalAlignment="Left"
                                    Width="0"
                                    Background="#FF4CAF50" />
                        </Grid>
                    </StackPanel>
                </Border>
                <StackPanel x:Name="OpenAiDetailsPanel" IsVisible="False">
            <StackPanel x:Name="OpenAiDirectSection" Margin="0,0,0,4" Spacing="2">
                <TextBlock Text="OpenAI API"
                           FontFamily="Segoe UI Semibold, Segoe UI, sans-serif"
                           FontSize="11"
                           FontWeight="SemiBold"
                           Foreground="#FFB0B0B0" />
                <Grid x:Name="OpenAiDirectProgressTrack"
                      Height="6">
                    <Border CornerRadius="3" Background="#33FFFFFF" />
                    <Border x:Name="OpenAiDirectProgressFill"
                            CornerRadius="3"
                            HorizontalAlignment="Left"
                            Width="0"
                            Background="#FF4CAF50" />
                </Grid>
            </StackPanel>
            <TextBlock x:Name="OpenAiDirectDetailText"
                       Margin="0,2,0,4"
                       FontSize="9"
                       LineHeight="12"
                       Foreground="#FF777777"
                       IsVisible="False" />
            <StackPanel x:Name="CodexLimitsSection" IsVisible="False">
                <TextBlock x:Name="CodexPercentText"
                           Text="..."
                           FontSize="11"
                           FontWeight="SemiBold"
                           LineHeight="15"
                           Foreground="#FFE8E8E8" />
                <Border x:Name="CodexBarBorder"
                        Background="Transparent"
                        PointerPressed="CodexLimits_PointerPressed">
                    <StackPanel Margin="0,5,0,5" Spacing="2">
                        <TextBlock Text="Codex"
                                   FontFamily="Segoe UI Semibold, Segoe UI, sans-serif"
                                   FontSize="11"
                                   FontWeight="SemiBold"
                                   Foreground="#FFB0B0B0" />
                        <Grid x:Name="CodexProgressTrack"
                              Height="6">
                            <Border CornerRadius="3" Background="#33FFFFFF" />
                            <Border x:Name="CodexProgressFill"
                                    CornerRadius="3"
                                    HorizontalAlignment="Left"
                                    Width="0"
                                    Background="#FF4CAF50" />
                        </Grid>
                    </StackPanel>
                </Border>
                <StackPanel x:Name="CodexBreakdownSection"
                            Margin="0,3,0,0"
                            IsVisible="False">
                    <StackPanel Orientation="Horizontal"
                                Spacing="4">
                        <TextBlock x:Name="CodexBreakdownChevron"
                                   Text="&#x25BE;"
                                   FontSize="8"
                                   LineHeight="11"
                                   Foreground="#FF888888"
                                   VerticalAlignment="Center" />
                        <TextBlock x:Name="CodexBreakdownSummary"
                                   Text=""
                                   FontSize="8"
                                   LineHeight="11"
                                   Foreground="#FF888888"
                                   VerticalAlignment="Center"
                                   TextWrapping="Wrap" />
                    </StackPanel>
                    <Border x:Name="CodexBreakdownPanel"
                            Margin="0,6,0,0"
                            Padding="8,7"
                            CornerRadius="6"
                            Background="#FF121212"
                            IsVisible="False">
                        <StackPanel Spacing="10">
                            <StackPanel x:Name="CodexSessionWindowSection">
                                <Grid Margin="0,0,0,4">
                                    <TextBlock Text="5h"
                                               FontSize="11"
                                               FontWeight="SemiBold"
                                               LineHeight="15"
                                               Foreground="#FFE8E8E8"
                                               HorizontalAlignment="Left" />
                                    <TextBlock x:Name="CodexSessionPercentText"
                                               Text=""
                                               FontSize="11"
                                               FontWeight="SemiBold"
                                               LineHeight="15"
                                               Foreground="#FFE8E8E8"
                                               HorizontalAlignment="Right" />
                                </Grid>
                                <Grid x:Name="CodexSessionProgressTrack" Height="6">
                                    <Border CornerRadius="3" Background="#33FFFFFF" />
                                    <Border x:Name="CodexSessionProgressFill"
                                            CornerRadius="3"
                                            HorizontalAlignment="Left"
                                            Width="0"
                                            Background="#FF4CAF50" />
                                </Grid>
                                <TextBlock Text="Rolling 5-hour usage window."
                                           FontSize="8"
                                           LineHeight="11"
                                           Foreground="#FF666666"
                                           TextWrapping="Wrap"
                                           Margin="0,4,0,0" />
                            </StackPanel>
                            <StackPanel x:Name="CodexWeeklyWindowSection">
                                <Grid Margin="0,0,0,4">
                                    <TextBlock Text="Weekly"
                                               FontSize="11"
                                               FontWeight="SemiBold"
                                               LineHeight="15"
                                               Foreground="#FFE8E8E8"
                                               HorizontalAlignment="Left" />
                                    <TextBlock x:Name="CodexWeeklyPercentText"
                                               Text=""
                                               FontSize="11"
                                               FontWeight="SemiBold"
                                               LineHeight="15"
                                               Foreground="#FFE8E8E8"
                                               HorizontalAlignment="Right" />
                                </Grid>
                                <Grid x:Name="CodexWeeklyProgressTrack" Height="6">
                                    <Border CornerRadius="3" Background="#33FFFFFF" />
                                    <Border x:Name="CodexWeeklyProgressFill"
                                            CornerRadius="3"
                                            HorizontalAlignment="Left"
                                            Width="0"
                                            Background="#FF4CAF50" />
                                </Grid>
                                <TextBlock Text="Rolling 7-day usage window."
                                           FontSize="8"
                                           LineHeight="11"
                                           Foreground="#FF666666"
                                           TextWrapping="Wrap"
                                           Margin="0,4,0,0" />
                            </StackPanel>
                        </StackPanel>
                    </Border>
                </StackPanel>
                <TextBlock x:Name="CodexRemainingText"
                           Text=""
                           FontSize="11"
                           LineHeight="15"
                           Foreground="#FFB0B0B0" />
            </StackPanel>
                </StackPanel>
            </StackPanel>
            <StackPanel x:Name="ClaudeProviderSection">
                <Border x:Name="ClaudeProviderHeader"
                        Background="Transparent"
                        Cursor="Hand"
                        Margin="0,0,0,4"
                        PointerPressed="ClaudeProvider_PointerPressed">
                    <StackPanel Spacing="2">
                        <TextBlock Text="Claude"
                                   FontFamily="Segoe UI Semibold, Segoe UI, sans-serif"
                                   FontSize="11"
                                   FontWeight="SemiBold"
                                   Foreground="#FFB0B0B0" />
                        <Grid x:Name="ClaudeHeadlineTrack"
                              Height="6">
                            <Border CornerRadius="3" Background="#33FFFFFF" />
                            <Border x:Name="ClaudeHeadlineFill"
                                    CornerRadius="3"
                                    HorizontalAlignment="Left"
                                    Width="0"
                                    Background="#FF4CAF50" />
                        </Grid>
                    </StackPanel>
                </Border>
                <StackPanel x:Name="ClaudeDetailsPanel" IsVisible="False">
            <StackPanel x:Name="ClaudeDirectSection" Margin="0,0,0,4" Spacing="2">
                <TextBlock Text="Claude API"
                           FontFamily="Segoe UI Semibold, Segoe UI, sans-serif"
                           FontSize="11"
                           FontWeight="SemiBold"
                           Foreground="#FFB0B0B0" />
                <Grid x:Name="ClaudeDirectProgressTrack"
                      Height="6">
                    <Border CornerRadius="3" Background="#33FFFFFF" />
                    <Border x:Name="ClaudeDirectProgressFill"
                            CornerRadius="3"
                            HorizontalAlignment="Left"
                            Width="0"
                            Background="#FF4CAF50" />
                </Grid>
            </StackPanel>
            <TextBlock x:Name="ClaudeDirectDetailText"
                       Margin="0,2,0,4"
                       FontSize="9"
                       LineHeight="12"
                       Foreground="#FF777777"
                       IsVisible="False" />
            <StackPanel x:Name="ClaudeProLimitsSection" IsVisible="False">
                <TextBlock x:Name="ClaudeProPercentText"
                           Text="..."
                           FontSize="11"
                           FontWeight="SemiBold"
                           LineHeight="15"
                           Foreground="#FFE8E8E8" />
                <Border x:Name="ClaudeProBarBorder"
                        Background="Transparent"
                        PointerPressed="ClaudeProLimits_PointerPressed">
                    <StackPanel Margin="0,5,0,5" Spacing="2">
                        <TextBlock Text="Claude.ai"
                                   FontFamily="Segoe UI Semibold, Segoe UI, sans-serif"
                                   FontSize="11"
                                   FontWeight="SemiBold"
                                   Foreground="#FFB0B0B0" />
                        <Grid x:Name="ClaudeProProgressTrack"
                              Height="6">
                            <Border CornerRadius="3" Background="#33FFFFFF" />
                            <Border x:Name="ClaudeProProgressFill"
                                    CornerRadius="3"
                                    HorizontalAlignment="Left"
                                    Width="0"
                                    Background="#FF4CAF50" />
                        </Grid>
                    </StackPanel>
                </Border>
                <StackPanel x:Name="ClaudeProBreakdownSection"
                            Margin="0,3,0,0"
                            IsVisible="False">
                    <StackPanel Orientation="Horizontal"
                                Spacing="4">
                        <TextBlock x:Name="ClaudeProBreakdownChevron"
                                   Text="&#x25BE;"
                                   FontSize="8"
                                   LineHeight="11"
                                   Foreground="#FF888888"
                                   VerticalAlignment="Center" />
                        <TextBlock x:Name="ClaudeProBreakdownSummary"
                                   Text=""
                                   FontSize="8"
                                   LineHeight="11"
                                   Foreground="#FF888888"
                                   VerticalAlignment="Center"
                                   TextWrapping="Wrap" />
                    </StackPanel>
                    <Border x:Name="ClaudeProBreakdownPanel"
                            Margin="0,6,0,0"
                            Padding="8,7"
                            CornerRadius="6"
                            Background="#FF121212"
                            IsVisible="False">
                        <StackPanel Spacing="10">
                            <StackPanel>
                                <Grid Margin="0,0,0,4">
                                    <TextBlock Text="5h"
                                               FontSize="11"
                                               FontWeight="SemiBold"
                                               LineHeight="15"
                                               Foreground="#FFE8E8E8"
                                               HorizontalAlignment="Left" />
                                    <TextBlock x:Name="ClaudeProSessionPercentText"
                                               Text=""
                                               FontSize="11"
                                               FontWeight="SemiBold"
                                               LineHeight="15"
                                               Foreground="#FFE8E8E8"
                                               HorizontalAlignment="Right" />
                                </Grid>
                                <Grid x:Name="ClaudeProSessionProgressTrack" Height="6">
                                    <Border CornerRadius="3" Background="#33FFFFFF" />
                                    <Border x:Name="ClaudeProSessionProgressFill"
                                            CornerRadius="3"
                                            HorizontalAlignment="Left"
                                            Width="0"
                                            Background="#FF4CAF50" />
                                </Grid>
                                <TextBlock Text="Rolling 5-hour usage window."
                                           FontSize="8"
                                           LineHeight="11"
                                           Foreground="#FF666666"
                                           TextWrapping="Wrap"
                                           Margin="0,4,0,0" />
                            </StackPanel>
                            <StackPanel>
                                <Grid Margin="0,0,0,4">
                                    <TextBlock Text="Weekly"
                                               FontSize="11"
                                               FontWeight="SemiBold"
                                               LineHeight="15"
                                               Foreground="#FFE8E8E8"
                                               HorizontalAlignment="Left" />
                                    <TextBlock x:Name="ClaudeProWeeklyPercentText"
                                               Text=""
                                               FontSize="11"
                                               FontWeight="SemiBold"
                                               LineHeight="15"
                                               Foreground="#FFE8E8E8"
                                               HorizontalAlignment="Right" />
                                </Grid>
                                <Grid x:Name="ClaudeProWeeklyProgressTrack" Height="6">
                                    <Border CornerRadius="3" Background="#33FFFFFF" />
                                    <Border x:Name="ClaudeProWeeklyProgressFill"
                                            CornerRadius="3"
                                            HorizontalAlignment="Left"
                                            Width="0"
                                            Background="#FF4CAF50" />
                                </Grid>
                                <TextBlock Text="Rolling 7-day usage window."
                                           FontSize="8"
                                           LineHeight="11"
                                           Foreground="#FF666666"
                                           TextWrapping="Wrap"
                                           Margin="0,4,0,0" />
                            </StackPanel>
                        </StackPanel>
                    </Border>
                </StackPanel>
                <TextBlock x:Name="ClaudeProRemainingText"
                           Text=""
                           FontSize="11"
                           LineHeight="15"
                           Foreground="#FFB0B0B0" />
            </StackPanel>
                </StackPanel>
            </StackPanel>
            <StackPanel x:Name="GeminiProviderSection">
                <Border x:Name="GeminiProviderHeader"
                        Background="Transparent"
                        Cursor="Hand"
                        Margin="0,0,0,4"
                        PointerPressed="GeminiProvider_PointerPressed">
                    <StackPanel Spacing="2">
                        <TextBlock Text="Gemini"
                                   FontFamily="Segoe UI Semibold, Segoe UI, sans-serif"
                                   FontSize="11"
                                   FontWeight="SemiBold"
                                   Foreground="#FFB0B0B0" />
                        <Grid x:Name="GeminiHeadlineTrack"
                              Height="6">
                            <Border CornerRadius="3" Background="#33FFFFFF" />
                            <Border x:Name="GeminiHeadlineFill"
                                    CornerRadius="3"
                                    HorizontalAlignment="Left"
                                    Width="0"
                                    Background="#FF4CAF50" />
                        </Grid>
                    </StackPanel>
                </Border>
                <StackPanel x:Name="GeminiDetailsPanel" IsVisible="False">
            <StackPanel x:Name="AntigravityLimitsSection" IsVisible="False">
                <TextBlock x:Name="AntigravityPercentText"
                           Text="..."
                           FontSize="11"
                           FontWeight="SemiBold"
                           LineHeight="15"
                           Foreground="#FFE8E8E8" />
                <Border x:Name="AntigravityBarBorder"
                        Background="Transparent"
                        PointerPressed="AntigravityLimits_PointerPressed">
                    <StackPanel Margin="0,5,0,5" Spacing="2">
                        <TextBlock Text="Gemini App"
                                   FontFamily="Segoe UI Semibold, Segoe UI, sans-serif"
                                   FontSize="11"
                                   FontWeight="SemiBold"
                                   Foreground="#FFB0B0B0" />
                        <Grid x:Name="AntigravityProgressTrack"
                              Height="6">
                            <Border CornerRadius="3" Background="#33FFFFFF" />
                            <Border x:Name="AntigravityProgressFill"
                                    CornerRadius="3"
                                    HorizontalAlignment="Left"
                                    Width="0"
                                    Background="#FF4CAF50" />
                        </Grid>
                    </StackPanel>
                </Border>
                <StackPanel x:Name="AntigravityBreakdownSection"
                            Margin="0,3,0,0"
                            IsVisible="False">
                    <StackPanel Orientation="Horizontal"
                                Spacing="4">
                        <TextBlock x:Name="AntigravityBreakdownChevron"
                                   Text="&#x25BE;"
                                   FontSize="8"
                                   LineHeight="11"
                                   Foreground="#FF888888"
                                   VerticalAlignment="Center" />
                        <TextBlock x:Name="AntigravityBreakdownSummary"
                                   Text=""
                                   FontSize="8"
                                   LineHeight="11"
                                   Foreground="#FF888888"
                                   VerticalAlignment="Center"
                                   TextWrapping="Wrap" />
                    </StackPanel>
                    <Border x:Name="AntigravityBreakdownPanel"
                            Margin="0,6,0,0"
                            Padding="8,7"
                            CornerRadius="6"
                            Background="#FF121212"
                            IsVisible="False">
                        <StackPanel Spacing="10">
                            <StackPanel>
                                <Grid Margin="0,0,0,4">
                                    <TextBlock Text="Gemini 5h"
                                               FontSize="11"
                                               FontWeight="SemiBold"
                                               LineHeight="15"
                                               Foreground="#FFE8E8E8"
                                               HorizontalAlignment="Left" />
                                    <TextBlock x:Name="AntigravityGeminiSessionPercentText"
                                               Text=""
                                               FontSize="11"
                                               FontWeight="SemiBold"
                                               LineHeight="15"
                                               Foreground="#FFE8E8E8"
                                               HorizontalAlignment="Right" />
                                </Grid>
                                <Grid x:Name="AntigravityGeminiSessionProgressTrack" Height="6">
                                    <Border CornerRadius="3" Background="#33FFFFFF" />
                                    <Border x:Name="AntigravityGeminiSessionProgressFill"
                                            CornerRadius="3"
                                            HorizontalAlignment="Left"
                                            Width="0"
                                            Background="#FF4CAF50" />
                                </Grid>
                            </StackPanel>
                            <StackPanel>
                                <Grid Margin="0,0,0,4">
                                    <TextBlock Text="Gemini weekly"
                                               FontSize="11"
                                               FontWeight="SemiBold"
                                               LineHeight="15"
                                               Foreground="#FFE8E8E8"
                                               HorizontalAlignment="Left" />
                                    <TextBlock x:Name="AntigravityGeminiWeeklyPercentText"
                                               Text=""
                                               FontSize="11"
                                               FontWeight="SemiBold"
                                               LineHeight="15"
                                               Foreground="#FFE8E8E8"
                                               HorizontalAlignment="Right" />
                                </Grid>
                                <Grid x:Name="AntigravityGeminiWeeklyProgressTrack" Height="6">
                                    <Border CornerRadius="3" Background="#33FFFFFF" />
                                    <Border x:Name="AntigravityGeminiWeeklyProgressFill"
                                            CornerRadius="3"
                                            HorizontalAlignment="Left"
                                            Width="0"
                                            Background="#FF4CAF50" />
                                </Grid>
                            </StackPanel>
                            <StackPanel>
                                <Grid Margin="0,0,0,4">
                                    <TextBlock Text="3P 5h"
                                               FontSize="11"
                                               FontWeight="SemiBold"
                                               LineHeight="15"
                                               Foreground="#FFE8E8E8"
                                               HorizontalAlignment="Left" />
                                    <TextBlock x:Name="AntigravityThirdPartySessionPercentText"
                                               Text=""
                                               FontSize="11"
                                               FontWeight="SemiBold"
                                               LineHeight="15"
                                               Foreground="#FFE8E8E8"
                                               HorizontalAlignment="Right" />
                                </Grid>
                                <Grid x:Name="AntigravityThirdPartySessionProgressTrack" Height="6">
                                    <Border CornerRadius="3" Background="#33FFFFFF" />
                                    <Border x:Name="AntigravityThirdPartySessionProgressFill"
                                            CornerRadius="3"
                                            HorizontalAlignment="Left"
                                            Width="0"
                                            Background="#FF4CAF50" />
                                </Grid>
                            </StackPanel>
                            <StackPanel>
                                <Grid Margin="0,0,0,4">
                                    <TextBlock Text="3P weekly"
                                               FontSize="11"
                                               FontWeight="SemiBold"
                                               LineHeight="15"
                                               Foreground="#FFE8E8E8"
                                               HorizontalAlignment="Left" />
                                    <TextBlock x:Name="AntigravityThirdPartyWeeklyPercentText"
                                               Text=""
                                               FontSize="11"
                                               FontWeight="SemiBold"
                                               LineHeight="15"
                                               Foreground="#FFE8E8E8"
                                               HorizontalAlignment="Right" />
                                </Grid>
                                <Grid x:Name="AntigravityThirdPartyWeeklyProgressTrack" Height="6">
                                    <Border CornerRadius="3" Background="#33FFFFFF" />
                                    <Border x:Name="AntigravityThirdPartyWeeklyProgressFill"
                                            CornerRadius="3"
                                            HorizontalAlignment="Left"
                                            Width="0"
                                            Background="#FF4CAF50" />
                                </Grid>
                            </StackPanel>
                        </StackPanel>
                    </Border>
                </StackPanel>
                <TextBlock x:Name="AntigravityRemainingText"
                           Text=""
                           FontSize="11"
                           LineHeight="15"
                           Foreground="#FFB0B0B0" />
            </StackPanel>
                </StackPanel>
            </StackPanel>
            <StackPanel x:Name="OpenRouterProviderSection">
                <Border x:Name="OpenRouterProviderHeader"
                        Background="Transparent"
                        Cursor="Hand"
                        Margin="0,0,0,4"
                        PointerPressed="OpenRouterProvider_PointerPressed">
                    <StackPanel Spacing="2">
                        <TextBlock Text="OpenRouter"
                                   FontFamily="Segoe UI Semibold, Segoe UI, sans-serif"
                                   FontSize="11"
                                   FontWeight="SemiBold"
                                   Foreground="#FFB0B0B0" />
                        <Grid x:Name="OpenRouterHeadlineTrack"
                              Height="6">
                            <Border CornerRadius="3" Background="#33FFFFFF" />
                            <Border x:Name="OpenRouterHeadlineFill"
                                    CornerRadius="3"
                                    HorizontalAlignment="Left"
                                    Width="0"
                                    Background="#FF4CAF50" />
                        </Grid>
                    </StackPanel>
                </Border>
                <StackPanel x:Name="OpenRouterDetailsPanel" IsVisible="False">
                    <StackPanel x:Name="OpenRouterLimitsSection" IsVisible="False">
                        <TextBlock x:Name="OpenRouterPercentText"
                                   Text="..."
                                   FontSize="11"
                                   FontWeight="SemiBold"
                                   LineHeight="15"
                                   Foreground="#FFE8E8E8" />
                        <StackPanel Margin="0,5,0,5" Spacing="2">
                            <TextBlock Text="Credits"
                                       FontFamily="Segoe UI Semibold, Segoe UI, sans-serif"
                                       FontSize="11"
                                       FontWeight="SemiBold"
                                       Foreground="#FFB0B0B0" />
                            <Grid x:Name="OpenRouterProgressTrack"
                                  Height="6">
                                <Border CornerRadius="3" Background="#33FFFFFF" />
                                <Border x:Name="OpenRouterProgressFill"
                                        CornerRadius="3"
                                        HorizontalAlignment="Left"
                                        Width="0"
                                        Background="#FF4CAF50" />
                            </Grid>
                        </StackPanel>
                        <TextBlock x:Name="OpenRouterDetailText"
                                   Margin="0,2,0,4"
                                   FontSize="9"
                                   LineHeight="12"
                                   Foreground="#FF777777"
                                   IsVisible="False" />
                    </StackPanel>
                </StackPanel>
            </StackPanel>
            <StackPanel x:Name="OpenCodeProviderSection">
                <Border x:Name="OpenCodeProviderHeader"
                        Background="Transparent"
                        Cursor="Hand"
                        Margin="0,0,0,4"
                        PointerPressed="OpenCodeProvider_PointerPressed">
                    <StackPanel Spacing="2">
                        <TextBlock Text="OpenCode"
                                   FontFamily="Segoe UI Semibold, Segoe UI, sans-serif"
                                   FontSize="11"
                                   FontWeight="SemiBold"
                                   Foreground="#FFB0B0B0" />
                        <Grid x:Name="OpenCodeHeadlineTrack"
                              Height="6">
                            <Border CornerRadius="3" Background="#33FFFFFF" />
                            <Border x:Name="OpenCodeHeadlineFill"
                                    CornerRadius="3"
                                    HorizontalAlignment="Left"
                                    Width="0"
                                    Background="#FF4CAF50" />
                        </Grid>
                    </StackPanel>
                </Border>
                <StackPanel x:Name="OpenCodeDetailsPanel" IsVisible="False">
                    <StackPanel x:Name="OpenCodeZenSection" Margin="0,0,0,4" IsVisible="False" Spacing="2">
                        <TextBlock Text="Zen"
                                   FontFamily="Segoe UI Semibold, Segoe UI, sans-serif"
                                   FontSize="11"
                                   FontWeight="SemiBold"
                                   Foreground="#FFB0B0B0" />
                        <Grid x:Name="OpenCodeZenProgressTrack"
                              Height="6">
                            <Border CornerRadius="3" Background="#33FFFFFF" />
                            <Border x:Name="OpenCodeZenProgressFill"
                                    CornerRadius="3"
                                    HorizontalAlignment="Left"
                                    Width="0"
                                    Background="#FF4CAF50" />
                        </Grid>
                    </StackPanel>
                    <TextBlock x:Name="OpenCodeZenDetailText"
                               Margin="0,2,0,4"
                               FontSize="9"
                               LineHeight="12"
                               Foreground="#FF777777"
                               IsVisible="False" />
                    <StackPanel x:Name="OpenCodeGoLimitsSection" IsVisible="False">
                        <TextBlock x:Name="OpenCodeGoPercentText"
                                   Text="..."
                                   FontSize="11"
                                   FontWeight="SemiBold"
                                   LineHeight="15"
                                   Foreground="#FFE8E8E8" />
                        <Border x:Name="OpenCodeGoBarBorder"
                                Background="Transparent"
                                PointerPressed="OpenCodeGoLimits_PointerPressed">
                            <StackPanel Margin="0,5,0,5" Spacing="2">
                                <TextBlock Text="Go"
                                           FontFamily="Segoe UI Semibold, Segoe UI, sans-serif"
                                           FontSize="11"
                                           FontWeight="SemiBold"
                                           Foreground="#FFB0B0B0" />
                                <Grid x:Name="OpenCodeGoProgressTrack"
                                      Height="6">
                                    <Border CornerRadius="3" Background="#33FFFFFF" />
                                    <Border x:Name="OpenCodeGoProgressFill"
                                            CornerRadius="3"
                                            HorizontalAlignment="Left"
                                            Width="0"
                                            Background="#FF4CAF50" />
                                </Grid>
                            </StackPanel>
                        </Border>
                        <StackPanel x:Name="OpenCodeGoBreakdownSection"
                                    Margin="0,3,0,0"
                                    IsVisible="False">
                            <StackPanel Orientation="Horizontal" Spacing="4">
                                <TextBlock x:Name="OpenCodeGoBreakdownChevron"
                                           Text="&#x25BE;"
                                           FontSize="8"
                                           LineHeight="11"
                                           Foreground="#FF888888"
                                           VerticalAlignment="Center" />
                                <TextBlock x:Name="OpenCodeGoBreakdownSummary"
                                           Text=""
                                           FontSize="8"
                                           LineHeight="11"
                                           Foreground="#FF888888"
                                           VerticalAlignment="Center"
                                           TextWrapping="Wrap" />
                            </StackPanel>
                            <Border x:Name="OpenCodeGoBreakdownPanel"
                                    Margin="0,6,0,0"
                                    Padding="8,7"
                                    CornerRadius="6"
                                    Background="#FF121212"
                                    IsVisible="False">
                                <StackPanel Spacing="10">
                                    <StackPanel>
                                        <Grid Margin="0,0,0,4">
                                            <TextBlock Text="5h"
                                                       FontSize="11"
                                                       FontWeight="SemiBold"
                                                       LineHeight="15"
                                                       Foreground="#FFE8E8E8"
                                                       HorizontalAlignment="Left" />
                                            <TextBlock x:Name="OpenCodeGoRollingPercentText"
                                                       Text=""
                                                       FontSize="11"
                                                       FontWeight="SemiBold"
                                                       LineHeight="15"
                                                       Foreground="#FFE8E8E8"
                                                       HorizontalAlignment="Right" />
                                        </Grid>
                                        <Grid x:Name="OpenCodeGoRollingProgressTrack" Height="6">
                                            <Border CornerRadius="3" Background="#33FFFFFF" />
                                            <Border x:Name="OpenCodeGoRollingProgressFill"
                                                    CornerRadius="3"
                                                    HorizontalAlignment="Left"
                                                    Width="0"
                                                    Background="#FF4CAF50" />
                                        </Grid>
                                    </StackPanel>
                                    <StackPanel>
                                        <Grid Margin="0,0,0,4">
                                            <TextBlock Text="Week"
                                                       FontSize="11"
                                                       FontWeight="SemiBold"
                                                       LineHeight="15"
                                                       Foreground="#FFE8E8E8"
                                                       HorizontalAlignment="Left" />
                                            <TextBlock x:Name="OpenCodeGoWeeklyPercentText"
                                                       Text=""
                                                       FontSize="11"
                                                       FontWeight="SemiBold"
                                                       LineHeight="15"
                                                       Foreground="#FFE8E8E8"
                                                       HorizontalAlignment="Right" />
                                        </Grid>
                                        <Grid x:Name="OpenCodeGoWeeklyProgressTrack" Height="6">
                                            <Border CornerRadius="3" Background="#33FFFFFF" />
                                            <Border x:Name="OpenCodeGoWeeklyProgressFill"
                                                    CornerRadius="3"
                                                    HorizontalAlignment="Left"
                                                    Width="0"
                                                    Background="#FF4CAF50" />
                                        </Grid>
                                    </StackPanel>
                                    <StackPanel>
                                        <Grid Margin="0,0,0,4">
                                            <TextBlock Text="Month"
                                                       FontSize="11"
                                                       FontWeight="SemiBold"
                                                       LineHeight="15"
                                                       Foreground="#FFE8E8E8"
                                                       HorizontalAlignment="Left" />
                                            <TextBlock x:Name="OpenCodeGoMonthlyPercentText"
                                                       Text=""
                                                       FontSize="11"
                                                       FontWeight="SemiBold"
                                                       LineHeight="15"
                                                       Foreground="#FFE8E8E8"
                                                       HorizontalAlignment="Right" />
                                        </Grid>
                                        <Grid x:Name="OpenCodeGoMonthlyProgressTrack" Height="6">
                                            <Border CornerRadius="3" Background="#33FFFFFF" />
                                            <Border x:Name="OpenCodeGoMonthlyProgressFill"
                                                    CornerRadius="3"
                                                    HorizontalAlignment="Left"
                                                    Width="0"
                                                    Background="#FF4CAF50" />
                                        </Grid>
                                    </StackPanel>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                        <TextBlock x:Name="OpenCodeGoRemainingText"
                                   Text=""
                                   FontSize="11"
                                   LineHeight="15"
                                   Foreground="#FFB0B0B0" />
                    </StackPanel>
                </StackPanel>
            </StackPanel>
            <StackPanel x:Name="HardwareSection"
                        Margin="0,6,0,0"
                        Spacing="4"
                        IsVisible="False" />
            <StackPanel x:Name="DiskSection"
                        Margin="0,6,0,0"
                        Spacing="4"
                        IsVisible="False" />
            <Grid Margin="0,9,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBlock x:Name="LastRefreshedText"
                           Grid.Column="0"
                           FontSize="8"
                           LineHeight="11"
                           Foreground="#44FFFFFF"
                           HorizontalAlignment="Left"
                           VerticalAlignment="Center"
                           IsVisible="False" />
                <StackPanel Grid.Column="1"
                            Orientation="Horizontal"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Center"
                            Spacing="0">
                    <TextBlock Text="built by "
                               FontSize="8.5"
                               LineHeight="12"
                               Foreground="#44FFFFFF"
                               VerticalAlignment="Center" />
                    <TextBlock Text="deac.online"
                               FontSize="8.5"
                               LineHeight="12"
                               Foreground="#55AAAAAA"
                               Cursor="Hand"
                               VerticalAlignment="Center"
                               PointerPressed="DeacLink_PointerPressed" />
                    <TextBlock Text=" @ "
                               FontSize="8.5"
                               LineHeight="12"
                               Foreground="#44FFFFFF"
                               VerticalAlignment="Center" />
                    <TextBlock Text="worldbuild.io"
                               FontSize="8.5"
                               LineHeight="12"
                               Foreground="#55AAAAAA"
                               Cursor="Hand"
                               VerticalAlignment="Center"
                               PointerPressed="WorldbuildLink_PointerPressed" />
                </StackPanel>
            </Grid>
        </StackPanel>
    </Border>
</Window>
