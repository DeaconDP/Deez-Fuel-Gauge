                                            HorizontalAlignment="Left"
                                            Width="0"
                                            Background="#FF4CAF50" />
                                </Grid>
                            </StackPanel>
                            <StackPanel>
                                <Grid Margin="0,0,0,4">
                                    <TextBlock Text="Gemini weekly"
                                               FontSize="10"
                                               LineHeight="13"
                                               Foreground="#FFE8E8E8"
                                               HorizontalAlignment="Left" />
