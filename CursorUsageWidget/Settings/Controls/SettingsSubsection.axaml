<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="using:CursorUsageWidget.Settings.Controls"
             x:Class="CursorUsageWidget.Settings.Controls.SettingsSubsection"
             x:DataType="controls:SettingsSubsection">
    <StackPanel Spacing="2">
        <Grid ColumnDefinitions="*,Auto">
            <TextBlock Text="{Binding Title, RelativeSource={RelativeSource AncestorType=controls:SettingsSubsection}}"
                       Classes="subsection-title" />
            <ContentPresenter Grid.Column="1"
                              Content="{Binding Actions, RelativeSource={RelativeSource AncestorType=controls:SettingsSubsection}}" />
        </Grid>
        <TextBlock Text="{Binding Status, RelativeSource={RelativeSource AncestorType=controls:SettingsSubsection}}"
                   Classes="status-text"
                   IsVisible="{Binding HasStatus, RelativeSource={RelativeSource AncestorType=controls:SettingsSubsection}}" />
        <TextBlock Text="{Binding HelpText, RelativeSource={RelativeSource AncestorType=controls:SettingsSubsection}}"
                   Classes="help-text"
                   IsVisible="{Binding HasHelpText, RelativeSource={RelativeSource AncestorType=controls:SettingsSubsection}}" />
        <ContentPresenter Content="{Binding Body, RelativeSource={RelativeSource AncestorType=controls:SettingsSubsection}}" />
    </StackPanel>
</UserControl>
