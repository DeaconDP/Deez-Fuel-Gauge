<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="using:CursorUsageWidget.Settings.Controls"
             x:Class="CursorUsageWidget.Settings.Controls.SettingsProviderCard"
             x:DataType="controls:SettingsProviderCard">
    <Border Classes="settings-provider-card">
        <StackPanel Spacing="3">
            <Border Background="Transparent"
                    Cursor="Hand"
                    PointerPressed="Header_PointerPressed">
                <Grid ColumnDefinitions="Auto,*,Auto">
                    <TextBlock Text="●"
                               FontSize="8"
                               Foreground="{Binding HeaderColor, RelativeSource={RelativeSource AncestorType=controls:SettingsProviderCard}}"
                               VerticalAlignment="Center"
                               Margin="0,0,5,0" />
                    <TextBlock Grid.Column="1"
                               Text="{Binding Title, RelativeSource={RelativeSource AncestorType=controls:SettingsProviderCard}}"
                               FontSize="10"
                               FontWeight="SemiBold"
                               Foreground="#FF00E5FF"
                               VerticalAlignment="Center" />
                    <TextBlock Grid.Column="2"
                               Text="{Binding Chevron, RelativeSource={RelativeSource AncestorType=controls:SettingsProviderCard}}"
                               FontSize="9"
                               Foreground="#FF888888"
                               VerticalAlignment="Center" />
                </Grid>
            </Border>
            <StackPanel Spacing="2"
                        IsVisible="{Binding IsExpanded, RelativeSource={RelativeSource AncestorType=controls:SettingsProviderCard}}">
                <Border Classes="subsection-divider" />
                <ContentPresenter Content="{Binding Body, RelativeSource={RelativeSource AncestorType=controls:SettingsProviderCard}}" />
            </StackPanel>
        </StackPanel>
    </Border>
</UserControl>
