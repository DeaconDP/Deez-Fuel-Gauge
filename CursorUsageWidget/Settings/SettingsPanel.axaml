<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:settings="using:CursorUsageWidget.Settings"
             x:Class="CursorUsageWidget.Settings.SettingsPanel"
             x:DataType="settings:SettingsPanelViewModel"
             PointerPressed="SettingsPanel_PointerPressed">
    <UserControl.Styles>
        <Style Selector="TextBlock.subsection-title">
            <Setter Property="FontSize" Value="9" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="#FFCCCCCC" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>
        <Style Selector="TextBlock.status-text">
            <Setter Property="FontSize" Value="8" />
            <Setter Property="Foreground" Value="#FF888888" />
            <Setter Property="TextTrimming" Value="CharacterEllipsis" />
            <Setter Property="MaxLines" Value="2" />
        </Style>
        <Style Selector="CheckBox.toggle-checkbox">
            <Setter Property="FontSize" Value="9" />
            <Setter Property="Foreground" Value="#FFE8E8E8" />
            <Setter Property="Margin" Value="0,0,10,0" />
        </Style>
        <Style Selector="Button.action-button">
            <Setter Property="FontSize" Value="8.5" />
            <Setter Property="Padding" Value="5,2" />
            <Setter Property="Margin" Value="4,0,0,0" />
        </Style>
        <Style Selector="Border.subsection-divider">
            <Setter Property="Height" Value="1" />
            <Setter Property="Background" Value="#22FFFFFF" />
            <Setter Property="Margin" Value="0,1" />
        </Style>
    </UserControl.Styles>
    <ScrollViewer MaxHeight="300"
                  HorizontalScrollBarVisibility="Disabled">
        <StackPanel Spacing="3">
            <!-- Cursor -->
            <Border Background="#FF0A0A0A"
                    BorderBrush="#33FFFFFF"
                    BorderThickness="1"
                    CornerRadius="4"
                    Padding="6,4">
                <StackPanel Spacing="3">
                    <Border Background="Transparent"
                            Cursor="Hand"
                            PointerPressed="CursorHeader_PointerPressed">
                        <Grid ColumnDefinitions="Auto,*,Auto">
                            <TextBlock Text="●"
                                       FontSize="8"
                                       Foreground="{Binding CursorHeaderColor}"
                                       VerticalAlignment="Center"
                                       Margin="0,0,5,0" />
                            <TextBlock Grid.Column="1"
                                       Text="Cursor"
                                       FontSize="10"
                                       FontWeight="SemiBold"
                                       Foreground="#FF00E5FF"
                                       VerticalAlignment="Center" />
                            <TextBlock Grid.Column="2"
                                       Text="{Binding CursorChevron}"
                                       FontSize="9"
                                       Foreground="#FF888888"
                                       VerticalAlignment="Center" />
                        </Grid>
                    </Border>
                    <StackPanel Spacing="2" IsVisible="{Binding IsCursorExpanded}">
                        <Border Classes="subsection-divider" />
                        <Grid ColumnDefinitions="*,Auto">
                            <TextBlock Text="{Binding CursorStatus}"
                                       Classes="status-text"
                                       VerticalAlignment="Center" />
                            <Button Grid.Column="1"
                                    Content="Setup"
                                    Classes="action-button"
                                    Click="EasySetupCursor_Click" />
                        </Grid>
                        <WrapPanel Orientation="Horizontal">
                            <CheckBox Content="Widget"
                                      Classes="toggle-checkbox"
                                      IsChecked="{Binding ShowCursor}" />
                            <CheckBox Content="Details"
                                      Classes="toggle-checkbox"
                                      IsChecked="{Binding ShowCursorDetails}" />
                            <CheckBox Content="Breakdown"
                                      Classes="toggle-checkbox"
                                      IsChecked="{Binding ShowBreakdown}" />
                        </WrapPanel>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- OpenAI -->
            <Border Background="#FF0A0A0A"
                    BorderBrush="#33FFFFFF"
                    BorderThickness="1"
                    CornerRadius="4"
                    Padding="6,4">
                <StackPanel Spacing="3">
                    <Border Background="Transparent"
                            Cursor="Hand"
                            PointerPressed="OpenAiHeader_PointerPressed">
                        <Grid ColumnDefinitions="Auto,*,Auto">
                            <TextBlock Text="●"
                                       FontSize="8"
                                       Foreground="{Binding OpenAiHeaderColor}"
                                       VerticalAlignment="Center"
                                       Margin="0,0,5,0" />
                            <TextBlock Grid.Column="1"
                                       Text="OpenAI"
                                       FontSize="10"
                                       FontWeight="SemiBold"
                                       Foreground="#FF00E5FF"
                                       VerticalAlignment="Center" />
                            <TextBlock Grid.Column="2"
                                       Text="{Binding OpenAiChevron}"
                                       FontSize="9"
                                       Foreground="#FF888888"
                                       VerticalAlignment="Center" />
                        </Grid>
                    </Border>
                    <StackPanel Spacing="2" IsVisible="{Binding IsOpenAiExpanded}">
                        <Border Classes="subsection-divider" />
                        <!-- Cursor plan spend -->
                        <TextBlock Text="Cursor plan spend"
                                   Classes="subsection-title" />
                        <TextBlock Text="{Binding OpenAiStatus}"
                                   Classes="status-text" />
                        <WrapPanel Orientation="Horizontal">
                            <CheckBox Content="Widget"
                                      Classes="toggle-checkbox"
                                      IsChecked="{Binding ShowOpenAi}" />
                            <CheckBox Content="Details"
                                      Classes="toggle-checkbox"
                                      IsChecked="{Binding ShowOpenAiDetails}" />
                        </WrapPanel>

                        <Border Classes="subsection-divider" />
                        <!-- Direct API -->
                        <Grid ColumnDefinitions="*,Auto">
                            <TextBlock Text="Direct API"
                                       Classes="subsection-title" />
                            <Button Grid.Column="1"
                                    Content="Test"
                                    Classes="action-button"
                                    Click="TestOpenAi_Click" />
                        </Grid>
                        <WrapPanel Orientation="Horizontal">
                            <CheckBox Content="Show"
                                      Classes="toggle-checkbox"
                                      IsChecked="{Binding ShowOpenAiDirect}" />
                            <CheckBox Content="Details"
                                      Classes="toggle-checkbox"
                                      IsChecked="{Binding ShowOpenAiDirectDetails}" />
                        </WrapPanel>
                        <StackPanel Spacing="2" IsVisible="{Binding ShowOpenAiDirectCredentials}">
                            <Grid ColumnDefinitions="*,Auto">
                                <TextBox x:Name="OpenAiApiKeyBox"
                                         Grid.Column="0"
                                         Watermark="{Binding OpenAiApiKeyWatermark}"
                                         PasswordChar="•"
                                         FontSize="9"
                                         LostFocus="OpenAiApiKeyBox_LostFocus" />
                                <Button Grid.Column="1"
                                        Content="Clear"
                                        FontSize="8"
                                        Padding="4,2"
                                        Margin="4,0,0,0"
                                        IsVisible="{Binding HasOpenAiApiKeySaved}"
                                        Click="ClearOpenAiApiKey_Click" />
                            </Grid>
                            <Grid ColumnDefinitions="*,8,*">
                                <TextBox Grid.Column="0"
                                         Watermark="Org ID (optional)"
                                         FontSize="9"
                                         Text="{Binding OpenAiOrgId}" />
                                <TextBox Grid.Column="2"
                                         Watermark="Budget USD"
                                         FontSize="9"
                                         Text="{Binding OpenAiBudget}" />
                            </Grid>
                        </StackPanel>

                        <Border Classes="subsection-divider" />
                        <!-- Codex limits -->
                        <Grid ColumnDefinitions="*,Auto,Auto">
                            <TextBlock Text="Codex limits"
                                       Classes="subsection-title" />
                            <Button Grid.Column="1"
                                    Content="Setup"
                                    Classes="action-button"
                                    Click="EasySetupOpenAi_Click" />
                            <Button Grid.Column="2"
                                    Content="Test"
                                    Classes="action-button"
                                    Click="TestCodex_Click" />
                        </Grid>
                        <TextBlock Text="{Binding CodexStatus}"
                                   Classes="status-text" />
                        <WrapPanel Orientation="Horizontal">
                            <CheckBox Content="Show"
                                      Classes="toggle-checkbox"
                                      IsChecked="{Binding ShowCodexLimits}" />
                            <CheckBox Content="Details"
                                      Classes="toggle-checkbox"
                                      IsChecked="{Binding ShowCodexDetails}" />
                            <CheckBox Content="5h / week"
                                      Classes="toggle-checkbox"
                                      IsChecked="{Binding ShowCodexBreakdown}" />
                        </WrapPanel>
                        <StackPanel Spacing="2" IsVisible="{Binding ShowCodexCredentials}">
                            <Grid ColumnDefinitions="*,Auto">
                                <TextBox x:Name="OpenAiSessionCookieBox"
                                         Grid.Column="0"
                                         Watermark="{Binding OpenAiSessionCookieWatermark}"
                                         PasswordChar="•"
                                         FontSize="9"
                                         LostFocus="OpenAiSessionCookieBox_LostFocus" />
                                <Button Grid.Column="1"
                                        Content="Clear"
                                        FontSize="8"
                                        Padding="4,2"
                                        Margin="4,0,0,0"
                                        IsVisible="{Binding HasOpenAiSessionCookieSaved}"
                                        Click="ClearOpenAiSessionCookie_Click" />
                            </Grid>
                            <TextBlock Text="Uses ~/.codex/auth.json when present."
                                       FontSize="8"
                                       Foreground="#FF666666"
                                       TextTrimming="CharacterEllipsis"
                                       MaxLines="1" />
                        </StackPanel>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- Claude -->
            <Border Background="#FF0A0A0A"
                    BorderBrush="#33FFFFFF"
                    BorderThickness="1"
                    CornerRadius="4"
                    Padding="6,4">
                <StackPanel Spacing="3">
                    <Border Background="Transparent"
                            Cursor="Hand"
                            PointerPressed="ClaudeHeader_PointerPressed">
                        <Grid ColumnDefinitions="Auto,*,Auto">
                            <TextBlock Text="●"
                                       FontSize="8"
                                       Foreground="{Binding ClaudeHeaderColor}"
                                       VerticalAlignment="Center"
                                       Margin="0,0,5,0" />
                            <TextBlock Grid.Column="1"
                                       Text="Claude"
                                       FontSize="10"
                                       FontWeight="SemiBold"
                                       Foreground="#FF00E5FF"
                                       VerticalAlignment="Center" />
                            <TextBlock Grid.Column="2"
                                       Text="{Binding ClaudeChevron}"
                                       FontSize="9"
                                       Foreground="#FF888888"
                                       VerticalAlignment="Center" />
                        </Grid>
                    </Border>
                    <StackPanel Spacing="2" IsVisible="{Binding IsClaudeExpanded}">
                        <Border Classes="subsection-divider" />
                        <!-- Cursor plan spend -->
                        <TextBlock Text="Cursor plan spend"
                                   Classes="subsection-title" />
                        <WrapPanel Orientation="Horizontal">
                            <CheckBox Content="Widget"
                                      Classes="toggle-checkbox"
                                      IsChecked="{Binding ShowClaude}" />
                            <CheckBox Content="Details"
                                      Classes="toggle-checkbox"
                                      IsChecked="{Binding ShowClaudeDetails}" />
                        </WrapPanel>

                        <Border Classes="subsection-divider" />
                        <!-- Claude Pro limits -->
                        <Grid ColumnDefinitions="*,Auto,Auto">
                            <TextBlock Text="Claude Pro"
                                       Classes="subsection-title" />
                            <Button Grid.Column="1"
                                    Content="Open"
                                    Classes="action-button"
                                    Click="OpenClaudeAi_Click" />
                            <Button Grid.Column="2"
                                    Content="Refresh"
                                    Classes="action-button"
                                    Click="RefreshClaudePro_Click" />
                        </Grid>
                        <TextBlock Text="{Binding ClaudeProStatus}"
                                   Classes="status-text" />
                        <TextBlock Text="Sign in at claude.ai, then click Refresh. Also reads Claude Code login (~/.claude/.credentials.json) when present."
                                   FontSize="8"
                                   Foreground="#FF666666"
                                   TextWrapping="Wrap"
                                   MaxLines="3" />
                        <WrapPanel Orientation="Horizontal">
                            <CheckBox Content="Show"
                                      Classes="toggle-checkbox"
                                      IsChecked="{Binding ShowClaudePro}" />
                            <CheckBox Content="Details"
                                      Classes="toggle-checkbox"
                                      IsChecked="{Binding ShowClaudeProDetails}" />
                            <CheckBox Content="5h / week"
                                      Classes="toggle-checkbox"
                                      IsChecked="{Binding ShowClaudeProBreakdown}" />
                        </WrapPanel>

                        <Border Classes="subsection-divider" />
                        <!-- API Console billing -->
                        <Grid ColumnDefinitions="*,Auto">
                            <TextBlock Text="API Console"
                                       Classes="subsection-title" />
                            <Button Grid.Column="1"
                                    Content="Test"
                                    Classes="action-button"
                                    Click="TestClaudeApiConsole_Click" />
                        </Grid>
                        <TextBlock Text="{Binding ClaudeApiConsoleStatus}"
                                   Classes="status-text" />
                        <WrapPanel Orientation="Horizontal">
                            <CheckBox Content="Show"
                                      Classes="toggle-checkbox"
                                      IsChecked="{Binding ShowClaudeApiConsole}" />
                            <CheckBox Content="Details"
                                      Classes="toggle-checkbox"
                                      IsChecked="{Binding ShowClaudeApiConsoleDetails}" />
                        </WrapPanel>
                        <StackPanel Spacing="2" IsVisible="{Binding ShowClaudeApiConsoleCredentials}">
                            <Grid ColumnDefinitions="*,Auto">
                                <TextBox x:Name="ClaudeApiKeyBox"
                                         Grid.Column="0"
                                         Watermark="{Binding ClaudeApiKeyWatermark}"
                                         PasswordChar="•"
                                         FontSize="9"
                                         LostFocus="ClaudeApiKeyBox_LostFocus" />
                                <Button Grid.Column="1"
                                        Content="Clear"
                                        FontSize="8"
                                        Padding="4,2"
                                        Margin="4,0,0,0"
                                        IsVisible="{Binding HasClaudeApiKeySaved}"
                                        Click="ClearClaudeApiKey_Click" />
                            </Grid>
                            <TextBox Watermark="Budget USD"
                                     FontSize="9"
                                     Text="{Binding ClaudeBudget}" />
                        </StackPanel>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- Gemini -->
            <Border Background="#FF0A0A0A"
                    BorderBrush="#33FFFFFF"
                    BorderThickness="1"
                    CornerRadius="4"
                    Padding="6,4">
                <StackPanel Spacing="3">
                    <Border Background="Transparent"
                            Cursor="Hand"
                            PointerPressed="GeminiHeader_PointerPressed">
                        <Grid ColumnDefinitions="Auto,*,Auto">
                            <TextBlock Text="●"
                                       FontSize="8"
                                       Foreground="{Binding GeminiHeaderColor}"
                                       VerticalAlignment="Center"
                                       Margin="0,0,5,0" />
                            <TextBlock Grid.Column="1"
                                       Text="Gemini &amp; Antigravity"
                                       FontSize="10"
                                       FontWeight="SemiBold"
                                       Foreground="#FF00E5FF"
                                       VerticalAlignment="Center" />
                            <TextBlock Grid.Column="2"
                                       Text="{Binding GeminiChevron}"
                                       FontSize="9"
                                       Foreground="#FF888888"
                                       VerticalAlignment="Center" />
                        </Grid>
                    </Border>
                    <StackPanel Spacing="2" IsVisible="{Binding IsGeminiExpanded}">
                        <Border Classes="subsection-divider" />
                        <!-- Cursor plan spend -->
                        <TextBlock Text="Cursor plan spend"
                                   Classes="subsection-title" />
                        <WrapPanel Orientation="Horizontal">
                            <CheckBox Content="Widget"
                                      Classes="toggle-checkbox"
                                      IsChecked="{Binding ShowGemini}" />
                            <CheckBox Content="Details"
                                      Classes="toggle-checkbox"
                                      IsChecked="{Binding ShowGeminiDetails}" />
                        </WrapPanel>

                        <Border Classes="subsection-divider" />
                        <!-- Antigravity limits -->
                        <Grid ColumnDefinitions="*,Auto,Auto">
                            <TextBlock Text="Antigravity"
                                       Classes="subsection-title" />
                            <Button Grid.Column="1"
                                    Content="Setup"
                                    Classes="action-button"
                                    Click="EasySetupGemini_Click" />
                            <Button Grid.Column="2"
                                    Content="Test"
                                    Classes="action-button"
                                    Click="TestAntigravity_Click" />
                        </Grid>
                        <TextBlock Text="{Binding AntigravityStatus}"
                                   Classes="status-text" />
                        <WrapPanel Orientation="Horizontal">
                            <CheckBox Content="Show"
                                      Classes="toggle-checkbox"
                                      IsChecked="{Binding ShowAntigravityLimits}" />
                            <CheckBox Content="Details"
                                      Classes="toggle-checkbox"
                                      IsChecked="{Binding ShowAntigravityDetails}" />
                            <CheckBox Content="5h / week"
                                      Classes="toggle-checkbox"
                                      IsChecked="{Binding ShowAntigravityBreakdown}" />
                        </WrapPanel>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- OpenRouter -->
            <Border Background="#FF0A0A0A"
                    BorderBrush="#33FFFFFF"
                    BorderThickness="1"
                    CornerRadius="4"
                    Padding="6,4">
                <StackPanel Spacing="3">
                    <Border Background="Transparent"
                            Cursor="Hand"
                            PointerPressed="OpenRouterHeader_PointerPressed">
                        <Grid ColumnDefinitions="Auto,*,Auto">
                            <TextBlock Text="●"
                                       FontSize="8"
                                       Foreground="{Binding OpenRouterHeaderColor}"
                                       VerticalAlignment="Center"
                                       Margin="0,0,5,0" />
                            <TextBlock Grid.Column="1"
                                       Text="OpenRouter"
                                       FontSize="10"
                                       FontWeight="SemiBold"
                                       Foreground="#FF00E5FF"
                                       VerticalAlignment="Center" />
                            <TextBlock Grid.Column="2"
                                       Text="{Binding OpenRouterChevron}"
                                       FontSize="9"
                                       Foreground="#FF888888"
                                       VerticalAlignment="Center" />
                        </Grid>
                    </Border>
                    <StackPanel Spacing="2" IsVisible="{Binding IsOpenRouterExpanded}">
                        <Border Classes="subsection-divider" />
                        <Grid ColumnDefinitions="*,Auto,Auto">
                            <TextBlock Text="Credits / limits"
                                       Classes="subsection-title" />
                            <Button Grid.Column="1"
                                    Content="Setup"
                                    Classes="action-button"
                                    Click="EasySetupOpenRouter_Click" />
                            <Button Grid.Column="2"
                                    Content="Test"
                                    Classes="action-button"
                                    Click="TestOpenRouter_Click" />
                        </Grid>
                        <TextBlock Text="{Binding OpenRouterStatus}"
                                   Classes="status-text" />
                        <WrapPanel Orientation="Horizontal">
                            <CheckBox Content="Show"
                                      Classes="toggle-checkbox"
                                      IsChecked="{Binding ShowOpenRouterLimits}" />
                            <CheckBox Content="Details"
                                      Classes="toggle-checkbox"
                                      IsChecked="{Binding ShowOpenRouterDetails}" />
                        </WrapPanel>
                        <Grid ColumnDefinitions="*,Auto">
                            <TextBox x:Name="OpenRouterApiKeyBox"
                                     Grid.Column="0"
                                     Watermark="{Binding OpenRouterApiKeyWatermark}"
                                     PasswordChar="•"
                                     FontSize="9"
                                     LostFocus="OpenRouterApiKeyBox_LostFocus" />
                            <Button Grid.Column="1"
                                    Content="Clear"
                                    FontSize="8"
                                    Padding="4,2"
                                    Margin="4,0,0,0"
                                    IsVisible="{Binding HasOpenRouterApiKeySaved}"
                                    Click="ClearOpenRouterApiKey_Click" />
                        </Grid>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- OpenCode -->
            <Border Background="#FF0A0A0A"
                    BorderBrush="#33FFFFFF"
                    BorderThickness="1"
                    CornerRadius="4"
                    Padding="6,4">
                <StackPanel Spacing="3">
                    <Border Background="Transparent"
                            Cursor="Hand"
                            PointerPressed="OpenCodeHeader_PointerPressed">
                        <Grid ColumnDefinitions="Auto,*,Auto">
                            <TextBlock Text="●"
                                       FontSize="8"
                                       Foreground="{Binding OpenCodeHeaderColor}"
                                       VerticalAlignment="Center"
                                       Margin="0,0,5,0" />
                            <TextBlock Grid.Column="1"
                                       Text="OpenCode"
                                       FontSize="10"
                                       FontWeight="SemiBold"
                                       Foreground="#FF00E5FF"
                                       VerticalAlignment="Center" />
                            <TextBlock Grid.Column="2"
                                       Text="{Binding OpenCodeChevron}"
                                       FontSize="9"
                                       Foreground="#FF888888"
                                       VerticalAlignment="Center" />
                        </Grid>
                    </Border>
                    <StackPanel Spacing="2" IsVisible="{Binding IsOpenCodeExpanded}">
                        <Border Classes="subsection-divider" />
                        <Grid ColumnDefinitions="*,Auto,Auto">
                            <TextBlock Text="Zen + Go"
                                       Classes="subsection-title" />
                            <Button Grid.Column="1"
                                    Content="Open"
                                    Classes="action-button"
                                    Click="OpenOpenCode_Click" />
                            <Button Grid.Column="2"
                                    Content="Test"
                                    Classes="action-button"
                                    Click="TestOpenCode_Click" />
                        </Grid>
                        <TextBlock Text="{Binding OpenCodeStatus}"
                                   Classes="status-text" />
                        <TextBlock Text="Sign in at opencode.ai, copy auth cookie from DevTools and workspace ID from URL."
                                   FontSize="8"
                                   Foreground="#FF666666"
                                   TextWrapping="Wrap"
                                   MaxLines="3" />
                        <TextBox Watermark="Workspace ID"
                                 FontSize="9"
                                 Text="{Binding OpenCodeWorkspaceId}" />
                        <Grid ColumnDefinitions="*,Auto">
                            <TextBox x:Name="OpenCodeSessionCookieBox"
                                     Grid.Column="0"
                                     Watermark="{Binding OpenCodeSessionWatermark}"
                                     PasswordChar="•"
                                     FontSize="9"
                                     LostFocus="OpenCodeSessionCookieBox_LostFocus" />
                            <Button Grid.Column="1"
                                    Content="Clear"
                                    FontSize="8"
                                    Padding="4,2"
                                    Margin="4,0,0,0"
                                    IsVisible="{Binding HasOpenCodeSessionSaved}"
                                    Click="ClearOpenCodeSessionCookie_Click" />
                        </Grid>
                        <WrapPanel Orientation="Horizontal">
                            <CheckBox Content="Zen"
                                      Classes="toggle-checkbox"
                                      IsChecked="{Binding ShowOpenCodeZen}" />
                            <CheckBox Content="Go"
                                      Classes="toggle-checkbox"
                                      IsChecked="{Binding ShowOpenCodeGo}" />
                            <CheckBox Content="Details"
                                      Classes="toggle-checkbox"
                                      IsChecked="{Binding ShowOpenCodeZenDetails}" />
                            <CheckBox Content="5h/wk/mo"
                                      Classes="toggle-checkbox"
                                      IsChecked="{Binding ShowOpenCodeGoBreakdown}" />
                        </WrapPanel>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- Disk -->
            <Border Background="#FF0A0A0A"
                    BorderBrush="#33FFFFFF"
                    BorderThickness="1"
                    CornerRadius="4"
                    Padding="6,4">
                <StackPanel Spacing="3">
                    <Border Background="Transparent"
                            Cursor="Hand"
                            PointerPressed="DiskHeader_PointerPressed">
                        <Grid ColumnDefinitions="Auto,*,Auto">
                            <TextBlock Text="●"
                                       FontSize="8"
                                       Foreground="{Binding DiskHeaderColor}"
                                       VerticalAlignment="Center"
                                       Margin="0,0,5,0" />
                            <TextBlock Grid.Column="1"
                                       Text="Disk"
                                       FontSize="10"
                                       FontWeight="SemiBold"
                                       Foreground="#FF00E5FF"
                                       VerticalAlignment="Center" />
                            <TextBlock Grid.Column="2"
                                       Text="{Binding DiskChevron}"
                                       FontSize="9"
                                       Foreground="#FF888888"
                                       VerticalAlignment="Center" />
                        </Grid>
                    </Border>
                    <StackPanel Spacing="2" IsVisible="{Binding IsDiskExpanded}">
                        <Border Classes="subsection-divider" />
                        <Grid ColumnDefinitions="*,Auto">
                            <TextBlock Text="Local drives"
                                       Classes="subsection-title" />
                            <Button Grid.Column="1"
                                    Content="Setup"
                                    Classes="action-button"
                                    Click="EasySetupDisk_Click" />
                        </Grid>
                        <WrapPanel Orientation="Horizontal">
                            <CheckBox Content="Drives"
                                      Classes="toggle-checkbox"
                                      IsChecked="{Binding ShowDiskDrives}" />
                            <CheckBox Content="Details"
                                      Classes="toggle-checkbox"
                                      IsChecked="{Binding ShowDiskDetails}" />
                        </WrapPanel>
                    </StackPanel>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</UserControl>
