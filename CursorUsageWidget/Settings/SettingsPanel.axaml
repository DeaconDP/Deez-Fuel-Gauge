<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:settings="using:CursorUsageWidget.Settings"
             xmlns:controls="using:CursorUsageWidget.Settings.Controls"
             x:Class="CursorUsageWidget.Settings.SettingsPanel"
             x:DataType="settings:SettingsPanelViewModel"
             PointerPressed="SettingsPanel_PointerPressed">
    <UserControl.Styles>
        <StyleInclude Source="avares://CursorUsageWidget/Settings/Controls/SettingsStyles.axaml" />
    </UserControl.Styles>
    <ScrollViewer MaxHeight="300"
                  HorizontalScrollBarVisibility="Disabled">
        <StackPanel Spacing="3">
            <controls:SettingsGroupHeader Title="Usage monitors" />

            <!-- Cursor -->
            <controls:SettingsProviderCard Title="Cursor"
                                           HeaderColor="{Binding CursorHeaderColor}"
                                           Chevron="{Binding CursorChevron}"
                                           IsExpanded="{Binding IsCursorExpanded}"
                                           HeaderPressed="CursorHeader_PointerPressed">
                <controls:SettingsProviderCard.Body>
                    <StackPanel Spacing="2">
                        <controls:SettingsSubsection Title="Included usage"
                                                     Status="{Binding CursorStatus}">
                            <controls:SettingsSubsection.Actions>
                                <Button Content="Setup"
                                        Classes="action-button"
                                        Click="EasySetupCursor_Click" />
                            </controls:SettingsSubsection.Actions>
                            <controls:SettingsSubsection.Body>
                                <WrapPanel Orientation="Horizontal">
                                    <CheckBox Content="Widget"
                                              Classes="toggle-checkbox"
                                              IsChecked="{Binding ShowCursor}" />
                                    <CheckBox Content="Details"
                                              Classes="toggle-checkbox"
                                              IsChecked="{Binding ShowCursorDetails}" />
                                    <CheckBox Content="Usage breakdown"
                                              Classes="toggle-checkbox"
                                              IsChecked="{Binding ShowBreakdown}" />
                                </WrapPanel>
                            </controls:SettingsSubsection.Body>
                        </controls:SettingsSubsection>
                    </StackPanel>
                </controls:SettingsProviderCard.Body>
            </controls:SettingsProviderCard>

            <!-- OpenAI -->
            <controls:SettingsProviderCard Title="OpenAI"
                                           HeaderColor="{Binding OpenAiHeaderColor}"
                                           Chevron="{Binding OpenAiChevron}"
                                           IsExpanded="{Binding IsOpenAiExpanded}"
                                           HeaderPressed="OpenAiHeader_PointerPressed">
                <controls:SettingsProviderCard.Body>
                    <StackPanel Spacing="2">
                        <controls:SettingsSubsection Title="Cursor plan spend"
                                                     Status="{Binding OpenAiCursorPlanStatus}">
                            <controls:SettingsSubsection.Body>
                                <WrapPanel Orientation="Horizontal">
                                    <CheckBox Content="Widget"
                                              Classes="toggle-checkbox"
                                              IsChecked="{Binding ShowOpenAi}" />
                                    <CheckBox Content="Details"
                                              Classes="toggle-checkbox"
                                              IsChecked="{Binding ShowOpenAiDetails}" />
                                </WrapPanel>
                            </controls:SettingsSubsection.Body>
                        </controls:SettingsSubsection>

                        <Border Classes="subsection-divider" />

                        <controls:SettingsSubsection Title="Codex limits"
                                                     Status="{Binding CodexStatus}">
                            <controls:SettingsSubsection.Actions>
                                <StackPanel Orientation="Horizontal">
                                    <Button Content="Setup"
                                            Classes="action-button"
                                            Click="EasySetupOpenAi_Click" />
                                    <Button Content="Test"
                                            Classes="action-button"
                                            Click="TestCodex_Click" />
                                </StackPanel>
                            </controls:SettingsSubsection.Actions>
                            <controls:SettingsSubsection.Body>
                                <StackPanel Spacing="2">
                                    <WrapPanel Orientation="Horizontal">
                                        <CheckBox Content="Show"
                                                  Classes="toggle-checkbox"
                                                  IsChecked="{Binding ShowCodexLimits}" />
                                        <CheckBox Content="Details"
                                                  Classes="toggle-checkbox"
                                                  IsChecked="{Binding ShowCodexDetails}" />
                                        <CheckBox Content="5h / week"
                                                  Classes="toggle-checkbox"
                                                  IsChecked="{Binding ShowCodexBreakdown}" />
                                    </WrapPanel>
                                    <StackPanel Spacing="2" IsVisible="{Binding ShowCodexCredentials}">
                                        <Grid ColumnDefinitions="*,Auto">
                                            <TextBox x:Name="OpenAiSessionCookieBox"
                                                     Grid.Column="0"
                                                     Watermark="{Binding OpenAiSessionCookieWatermark}"
                                                     PasswordChar="•"
                                                     FontSize="9"
                                                     LostFocus="OpenAiSessionCookieBox_LostFocus" />
                                            <Button Grid.Column="1"
                                                    Content="Clear"
                                                    FontSize="8"
                                                    Padding="4,2"
                                                    Margin="4,0,0,0"
                                                    IsVisible="{Binding HasOpenAiSessionCookieSaved}"
                                                    Click="ClearOpenAiSessionCookie_Click" />
                                        </Grid>
                                        <TextBlock Text="Uses ~/.codex/auth.json when present."
                                                   FontSize="8"
                                                   Foreground="#FF666666"
                                                   TextTrimming="CharacterEllipsis"
                                                   MaxLines="1" />
                                    </StackPanel>
                                </StackPanel>
                            </controls:SettingsSubsection.Body>
                        </controls:SettingsSubsection>

                        <Border Classes="subsection-divider" />

                        <controls:SettingsSubsection Title="Platform API">
                            <controls:SettingsSubsection.Actions>
                                <Button Content="Test"
                                        Classes="action-button"
                                        Click="TestOpenAi_Click" />
                            </controls:SettingsSubsection.Actions>
                            <controls:SettingsSubsection.Body>
                                <StackPanel Spacing="2">
                                    <WrapPanel Orientation="Horizontal">
                                        <CheckBox Content="Show"
                                                  Classes="toggle-checkbox"
                                                  IsChecked="{Binding ShowOpenAiDirect}" />
                                        <CheckBox Content="Details"
                                                  Classes="toggle-checkbox"
                                                  IsChecked="{Binding ShowOpenAiDirectDetails}" />
                                    </WrapPanel>
                                    <StackPanel Spacing="2" IsVisible="{Binding ShowOpenAiDirectCredentials}">
                                        <Grid ColumnDefinitions="*,Auto">
                                            <TextBox x:Name="OpenAiApiKeyBox"
                                                     Grid.Column="0"
                                                     Watermark="{Binding OpenAiApiKeyWatermark}"
                                                     PasswordChar="•"
                                                     FontSize="9"
                                                     LostFocus="OpenAiApiKeyBox_LostFocus" />
                                            <Button Grid.Column="1"
                                                    Content="Clear"
                                                    FontSize="8"
                                                    Padding="4,2"
                                                    Margin="4,0,0,0"
                                                    IsVisible="{Binding HasOpenAiApiKeySaved}"
                                                    Click="ClearOpenAiApiKey_Click" />
                                        </Grid>
                                        <Grid ColumnDefinitions="*,8,*">
                                            <TextBox Grid.Column="0"
                                                     Watermark="Org ID (optional)"
                                                     FontSize="9"
                                                     Text="{Binding OpenAiOrgId}" />
                                            <TextBox Grid.Column="2"
                                                     Watermark="Budget USD"
                                                     FontSize="9"
                                                     Text="{Binding OpenAiBudget}" />
                                        </Grid>
                                    </StackPanel>
                                </StackPanel>
                            </controls:SettingsSubsection.Body>
                        </controls:SettingsSubsection>
                    </StackPanel>
                </controls:SettingsProviderCard.Body>
            </controls:SettingsProviderCard>

            <!-- Claude -->
            <controls:SettingsProviderCard Title="Claude"
                                           HeaderColor="{Binding ClaudeHeaderColor}"
                                           Chevron="{Binding ClaudeChevron}"
                                           IsExpanded="{Binding IsClaudeExpanded}"
                                           HeaderPressed="ClaudeHeader_PointerPressed">
                <controls:SettingsProviderCard.Body>
                    <StackPanel Spacing="2">
                        <controls:SettingsSubsection Title="Cursor plan spend"
                                                     Status="{Binding ClaudeCursorPlanStatus}">
                            <controls:SettingsSubsection.Body>
                                <WrapPanel Orientation="Horizontal">
                                    <CheckBox Content="Widget"
                                              Classes="toggle-checkbox"
                                              IsChecked="{Binding ShowClaude}" />
                                    <CheckBox Content="Details"
                                              Classes="toggle-checkbox"
                                              IsChecked="{Binding ShowClaudeDetails}" />
                                </WrapPanel>
                            </controls:SettingsSubsection.Body>
                        </controls:SettingsSubsection>

                        <Border Classes="subsection-divider" />

                        <controls:SettingsSubsection Title="Claude Pro"
                                                     Status="{Binding ClaudeProStatus}"
                                                     HelpText="Sign in at claude.ai, then click Refresh. Also reads Claude Code login (~/.claude/.credentials.json) when present.">
                            <controls:SettingsSubsection.Actions>
                                <StackPanel Orientation="Horizontal">
                                    <Button Content="Setup"
                                            Classes="action-button"
                                            Click="EasySetupClaude_Click" />
                                    <Button Content="Open"
                                            Classes="action-button"
                                            Click="OpenClaudeAi_Click" />
                                    <Button Content="Refresh"
                                            Classes="action-button"
                                            Click="RefreshClaudePro_Click" />
                                </StackPanel>
                            </controls:SettingsSubsection.Actions>
                            <controls:SettingsSubsection.Body>
                                <WrapPanel Orientation="Horizontal">
                                    <CheckBox Content="Show"
                                              Classes="toggle-checkbox"
                                              IsChecked="{Binding ShowClaudePro}" />
                                    <CheckBox Content="Details"
                                              Classes="toggle-checkbox"
                                              IsChecked="{Binding ShowClaudeProDetails}" />
                                    <CheckBox Content="5h / week"
                                              Classes="toggle-checkbox"
                                              IsChecked="{Binding ShowClaudeProBreakdown}" />
                                </WrapPanel>
                            </controls:SettingsSubsection.Body>
                        </controls:SettingsSubsection>

                        <Border Classes="subsection-divider" />

                        <controls:SettingsSubsection Title="API Console"
                                                     Status="{Binding ClaudeApiConsoleStatus}">
                            <controls:SettingsSubsection.Actions>
                                <Button Content="Test"
                                        Classes="action-button"
                                        Click="TestClaudeApiConsole_Click" />
                            </controls:SettingsSubsection.Actions>
                            <controls:SettingsSubsection.Body>
                                <StackPanel Spacing="2">
                                    <WrapPanel Orientation="Horizontal">
                                        <CheckBox Content="Show"
                                                  Classes="toggle-checkbox"
                                                  IsChecked="{Binding ShowClaudeApiConsole}" />
                                        <CheckBox Content="Details"
                                                  Classes="toggle-checkbox"
                                                  IsChecked="{Binding ShowClaudeApiConsoleDetails}" />
                                    </WrapPanel>
                                    <StackPanel Spacing="2" IsVisible="{Binding ShowClaudeApiConsoleCredentials}">
                                        <Grid ColumnDefinitions="*,Auto">
                                            <TextBox x:Name="ClaudeApiKeyBox"
                                                     Grid.Column="0"
                                                     Watermark="{Binding ClaudeApiKeyWatermark}"
                                                     PasswordChar="•"
                                                     FontSize="9"
                                                     LostFocus="ClaudeApiKeyBox_LostFocus" />
                                            <Button Grid.Column="1"
                                                    Content="Clear"
                                                    FontSize="8"
                                                    Padding="4,2"
                                                    Margin="4,0,0,0"
                                                    IsVisible="{Binding HasClaudeApiKeySaved}"
                                                    Click="ClearClaudeApiKey_Click" />
                                        </Grid>
                                        <TextBox Watermark="Budget USD"
                                                 FontSize="9"
                                                 Text="{Binding ClaudeBudget}" />
                                    </StackPanel>
                                </StackPanel>
                            </controls:SettingsSubsection.Body>
                        </controls:SettingsSubsection>
                    </StackPanel>
                </controls:SettingsProviderCard.Body>
            </controls:SettingsProviderCard>

            <!-- Gemini -->
            <controls:SettingsProviderCard Title="Gemini &amp; Antigravity"
                                           HeaderColor="{Binding GeminiHeaderColor}"
                                           Chevron="{Binding GeminiChevron}"
                                           IsExpanded="{Binding IsGeminiExpanded}"
                                           HeaderPressed="GeminiHeader_PointerPressed">
                <controls:SettingsProviderCard.Body>
                    <StackPanel Spacing="2">
                        <controls:SettingsSubsection Title="Cursor plan spend"
                                                     Status="{Binding GeminiCursorPlanStatus}">
                            <controls:SettingsSubsection.Body>
                                <WrapPanel Orientation="Horizontal">
                                    <CheckBox Content="Widget"
                                              Classes="toggle-checkbox"
                                              IsChecked="{Binding ShowGemini}" />
                                    <CheckBox Content="Details"
                                              Classes="toggle-checkbox"
                                              IsChecked="{Binding ShowGeminiDetails}" />
                                </WrapPanel>
                            </controls:SettingsSubsection.Body>
                        </controls:SettingsSubsection>

                        <Border Classes="subsection-divider" />

                        <controls:SettingsSubsection Title="Antigravity"
                                                     Status="{Binding AntigravityStatus}">
                            <controls:SettingsSubsection.Actions>
                                <StackPanel Orientation="Horizontal">
                                    <Button Content="Setup"
                                            Classes="action-button"
                                            Click="EasySetupGemini_Click" />
                                    <Button Content="Test"
                                            Classes="action-button"
                                            Click="TestAntigravity_Click" />
                                </StackPanel>
                            </controls:SettingsSubsection.Actions>
                            <controls:SettingsSubsection.Body>
                                <WrapPanel Orientation="Horizontal">
                                    <CheckBox Content="Show"
                                              Classes="toggle-checkbox"
                                              IsChecked="{Binding ShowAntigravityLimits}" />
                                    <CheckBox Content="Details"
                                              Classes="toggle-checkbox"
                                              IsChecked="{Binding ShowAntigravityDetails}" />
                                    <CheckBox Content="5h / week"
                                              Classes="toggle-checkbox"
                                              IsChecked="{Binding ShowAntigravityBreakdown}" />
                                </WrapPanel>
                            </controls:SettingsSubsection.Body>
                        </controls:SettingsSubsection>
                    </StackPanel>
                </controls:SettingsProviderCard.Body>
            </controls:SettingsProviderCard>

            <!-- OpenRouter -->
            <controls:SettingsProviderCard Title="OpenRouter"
                                           HeaderColor="{Binding OpenRouterHeaderColor}"
                                           Chevron="{Binding OpenRouterChevron}"
                                           IsExpanded="{Binding IsOpenRouterExpanded}"
                                           HeaderPressed="OpenRouterHeader_PointerPressed">
                <controls:SettingsProviderCard.Body>
                    <StackPanel Spacing="2">
                        <controls:SettingsSubsection Title="Credits &amp; limits"
                                                     Status="{Binding OpenRouterStatus}">
                            <controls:SettingsSubsection.Actions>
                                <StackPanel Orientation="Horizontal">
                                    <Button Content="Setup"
                                            Classes="action-button"
                                            Click="EasySetupOpenRouter_Click" />
                                    <Button Content="Test"
                                            Classes="action-button"
                                            Click="TestOpenRouter_Click" />
                                </StackPanel>
                            </controls:SettingsSubsection.Actions>
                            <controls:SettingsSubsection.Body>
                                <StackPanel Spacing="2">
                                    <WrapPanel Orientation="Horizontal">
                                        <CheckBox Content="Show"
                                                  Classes="toggle-checkbox"
                                                  IsChecked="{Binding ShowOpenRouterLimits}" />
                                        <CheckBox Content="Details"
                                                  Classes="toggle-checkbox"
                                                  IsChecked="{Binding ShowOpenRouterDetails}" />
                                    </WrapPanel>
                                    <Grid ColumnDefinitions="*,Auto"
                                          IsVisible="{Binding ShowOpenRouterCredentials}">
                                        <TextBox x:Name="OpenRouterApiKeyBox"
                                                 Grid.Column="0"
                                                 Watermark="{Binding OpenRouterApiKeyWatermark}"
                                                 PasswordChar="•"
                                                 FontSize="9"
                                                 LostFocus="OpenRouterApiKeyBox_LostFocus" />
                                        <Button Grid.Column="1"
                                                Content="Clear"
                                                FontSize="8"
                                                Padding="4,2"
                                                Margin="4,0,0,0"
                                                IsVisible="{Binding HasOpenRouterApiKeySaved}"
                                                Click="ClearOpenRouterApiKey_Click" />
                                    </Grid>
                                </StackPanel>
                            </controls:SettingsSubsection.Body>
                        </controls:SettingsSubsection>
                    </StackPanel>
                </controls:SettingsProviderCard.Body>
            </controls:SettingsProviderCard>

            <!-- OpenCode -->
            <controls:SettingsProviderCard Title="OpenCode"
                                           HeaderColor="{Binding OpenCodeHeaderColor}"
                                           Chevron="{Binding OpenCodeChevron}"
                                           IsExpanded="{Binding IsOpenCodeExpanded}"
                                           HeaderPressed="OpenCodeHeader_PointerPressed">
                <controls:SettingsProviderCard.Body>
                    <StackPanel Spacing="2">
                        <controls:SettingsSubsection Title="Account"
                                                     Status="{Binding OpenCodeStatus}"
                                                     HelpText="Sign in at opencode.ai, copy auth cookie from DevTools and workspace ID from URL.">
                            <controls:SettingsSubsection.Actions>
                                <StackPanel Orientation="Horizontal">
                                    <Button Content="Setup"
                                            Classes="action-button"
                                            Click="EasySetupOpenCode_Click" />
                                    <Button Content="Open"
                                            Classes="action-button"
                                            Click="OpenOpenCode_Click" />
                                    <Button Content="Test"
                                            Classes="action-button"
                                            Click="TestOpenCode_Click" />
                                </StackPanel>
                            </controls:SettingsSubsection.Actions>
                            <controls:SettingsSubsection.Body>
                                <StackPanel Spacing="2">
                                    <TextBox Watermark="Workspace ID"
                                             FontSize="9"
                                             Text="{Binding OpenCodeWorkspaceId}" />
                                    <Grid ColumnDefinitions="*,Auto">
                                        <TextBox x:Name="OpenCodeSessionCookieBox"
                                                 Grid.Column="0"
                                                 Watermark="{Binding OpenCodeSessionWatermark}"
                                                 PasswordChar="•"
                                                 FontSize="9"
                                                 LostFocus="OpenCodeSessionCookieBox_LostFocus" />
                                        <Button Grid.Column="1"
                                                Content="Clear"
                                                FontSize="8"
                                                Padding="4,2"
                                                Margin="4,0,0,0"
                                                IsVisible="{Binding HasOpenCodeSessionSaved}"
                                                Click="ClearOpenCodeSessionCookie_Click" />
                                    </Grid>
                                </StackPanel>
                            </controls:SettingsSubsection.Body>
                        </controls:SettingsSubsection>

                        <Border Classes="subsection-divider" />

                        <controls:SettingsSubsection Title="Zen">
                            <controls:SettingsSubsection.Body>
                                <WrapPanel Orientation="Horizontal">
                                    <CheckBox Content="Show"
                                              Classes="toggle-checkbox"
                                              IsChecked="{Binding ShowOpenCodeZen}" />
                                    <CheckBox Content="Details"
                                              Classes="toggle-checkbox"
                                              IsChecked="{Binding ShowOpenCodeZenDetails}" />
                                </WrapPanel>
                            </controls:SettingsSubsection.Body>
                        </controls:SettingsSubsection>

                        <Border Classes="subsection-divider" />

                        <controls:SettingsSubsection Title="Go">
                            <controls:SettingsSubsection.Body>
                                <WrapPanel Orientation="Horizontal">
                                    <CheckBox Content="Show"
                                              Classes="toggle-checkbox"
                                              IsChecked="{Binding ShowOpenCodeGo}" />
                                    <CheckBox Content="Details"
                                              Classes="toggle-checkbox"
                                              IsChecked="{Binding ShowOpenCodeGoDetails}" />
                                    <CheckBox Content="5h/wk/mo"
                                              Classes="toggle-checkbox"
                                              IsChecked="{Binding ShowOpenCodeGoBreakdown}" />
                                </WrapPanel>
                            </controls:SettingsSubsection.Body>
                        </controls:SettingsSubsection>
                    </StackPanel>
                </controls:SettingsProviderCard.Body>
            </controls:SettingsProviderCard>

            <controls:SettingsGroupHeader Title="System" />

            <!-- Widget -->
            <controls:SettingsProviderCard Title="Widget"
                                           HeaderColor="{Binding WidgetHeaderColor}"
                                           Chevron="{Binding WidgetChevron}"
                                           IsExpanded="{Binding IsWidgetExpanded}"
                                           HeaderPressed="WidgetHeader_PointerPressed">
                <controls:SettingsProviderCard.Body>
                    <StackPanel Spacing="6">
                        <controls:SettingsSubsection Title="Refresh interval (minutes)">
                            <controls:SettingsSubsection.Body>
                                <TextBox Text="{Binding RefreshIntervalText}"
                                         Watermark="5"
                                         FontSize="9" />
                            </controls:SettingsSubsection.Body>
                        </controls:SettingsSubsection>
                        <controls:SettingsSubsection Title="Launch at login">
                            <controls:SettingsSubsection.Body>
                                <CheckBox Content="Start when you sign in"
                                          Classes="toggle-checkbox"
                                          IsChecked="{Binding LaunchAtLogin}" />
                            </controls:SettingsSubsection.Body>
                        </controls:SettingsSubsection>
                        <controls:SettingsSubsection Title="Unused quota alerts">
                            <controls:SettingsSubsection.Body>
                                <StackPanel Spacing="6">
                                    <CheckBox Content="Warn when quota may expire unused"
                                              Classes="toggle-checkbox"
                                              IsChecked="{Binding QuotaAlertsEnabled}" />
                                    <TextBlock Text="Days before period ends"
                                               FontSize="9"
                                               Foreground="#FFAAAAAA"
                                               Margin="0,2,0,0" />
                                    <TextBox Text="{Binding QuotaAlertDaysBeforeEndText}"
                                             Watermark="7"
                                             FontSize="9" />
                                    <TextBlock Text="Alert when usage below (%)"
                                               FontSize="9"
                                               Foreground="#FFAAAAAA"
                                               Margin="0,2,0,0" />
                                    <TextBox Text="{Binding QuotaAlertMaxPercentUsedText}"
                                             Watermark="75"
                                             FontSize="9" />
                                    <TextBlock Text="Sources"
                                               FontSize="9"
                                               FontWeight="SemiBold"
                                               Foreground="#FFAAAAAA"
                                               Margin="0,2,0,0" />
                                    <CheckBox Content="Cursor plan"
                                              Classes="toggle-checkbox"
                                              IsChecked="{Binding QuotaAlertCursorPlan}" />
                                    <CheckBox Content="OpenAI (Cursor plan)"
                                              Classes="toggle-checkbox"
                                              IsChecked="{Binding QuotaAlertOpenAiCursor}" />
                                    <CheckBox Content="OpenAI Platform budget"
                                              Classes="toggle-checkbox"
                                              IsChecked="{Binding QuotaAlertOpenAiPlatform}" />
                                    <CheckBox Content="Claude (Cursor plan)"
                                              Classes="toggle-checkbox"
                                              IsChecked="{Binding QuotaAlertClaudeCursor}" />
                                    <CheckBox Content="Claude API Console budget"
                                              Classes="toggle-checkbox"
                                              IsChecked="{Binding QuotaAlertClaudeApi}" />
                                    <CheckBox Content="Gemini (Cursor plan)"
                                              Classes="toggle-checkbox"
                                              IsChecked="{Binding QuotaAlertGeminiCursor}" />
                                    <CheckBox Content="OpenRouter key limit"
                                              Classes="toggle-checkbox"
                                              IsChecked="{Binding QuotaAlertOpenRouterKeyLimit}" />
                                    <CheckBox Content="OpenCode Zen monthly"
                                              Classes="toggle-checkbox"
                                              IsChecked="{Binding QuotaAlertOpenCodeZenMonthly}" />
                                    <CheckBox Content="OpenCode Go monthly"
                                              Classes="toggle-checkbox"
                                              IsChecked="{Binding QuotaAlertOpenCodeGoMonthly}" />
                                </StackPanel>
                            </controls:SettingsSubsection.Body>
                        </controls:SettingsSubsection>
                    </StackPanel>
                </controls:SettingsProviderCard.Body>
            </controls:SettingsProviderCard>

            <!-- Disk -->
            <controls:SettingsProviderCard Title="Disk"
                                           HeaderColor="{Binding DiskHeaderColor}"
                                           Chevron="{Binding DiskChevron}"
                                           IsExpanded="{Binding IsDiskExpanded}"
                                           HeaderPressed="DiskHeader_PointerPressed">
                <controls:SettingsProviderCard.Body>
                    <StackPanel Spacing="2">
                        <controls:SettingsSubsection Title="Local drives">
                            <controls:SettingsSubsection.Actions>
                                <Button Content="Setup"
                                        Classes="action-button"
                                        Click="EasySetupDisk_Click" />
                            </controls:SettingsSubsection.Actions>
                            <controls:SettingsSubsection.Body>
                                <WrapPanel Orientation="Horizontal">
                                    <CheckBox Content="Show"
                                              Classes="toggle-checkbox"
                                              IsChecked="{Binding ShowDiskDrives}" />
                                    <CheckBox Content="Details"
                                              Classes="toggle-checkbox"
                                              IsChecked="{Binding ShowDiskDetails}" />
                                </WrapPanel>
                            </controls:SettingsSubsection.Body>
                        </controls:SettingsSubsection>
                    </StackPanel>
                </controls:SettingsProviderCard.Body>
            </controls:SettingsProviderCard>
        </StackPanel>
    </ScrollViewer>
</UserControl>
