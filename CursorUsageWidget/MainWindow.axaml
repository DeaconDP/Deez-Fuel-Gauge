<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="CursorUsageWidget.MainWindow"
        Title="Cursor Usage"
        Width="230"
        SizeToContent="Height"
        ExtendClientAreaChromeHints="NoChrome"
        ExtendClientAreaToDecorationsHint="True"
        TransparencyLevelHint="Transparent"
        Background="Transparent"
        CanResize="False"
        ShowInTaskbar="False"
        Topmost="True"
        PointerPressed="Window_PointerPressed">
    <Border x:Name="PillBorder"
            CornerRadius="10"
            Background="#E6181818"
            BorderBrush="#44FFFFFF"
            BorderThickness="1"
            Padding="10,9,10,10">
        <Border.ContextMenu>
            <ContextMenu>
                <MenuItem Header="Refresh" Click="RefreshMenuItem_Click" />
                <Separator />
                <MenuItem Header="Quit" Click="QuitMenuItem_Click" />
            </ContextMenu>
        </Border.ContextMenu>
        <StackPanel>
            <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                <TextBlock Text="&#x1F701;"
                           FontSize="15"
                           LineHeight="18"
                           Foreground="#CC00E5FF"
                           Margin="0,0,7,0"
                           VerticalAlignment="Center" />
                <TextBlock Text="Deez Fuel Guage"
                           FontFamily="Segoe UI Semibold, Segoe UI, sans-serif"
                           FontSize="13"
                           FontWeight="SemiBold"
                           LineHeight="18"
                           Foreground="#FF00E5FF"
                           VerticalAlignment="Center" />
            </StackPanel>
            <TextBlock x:Name="PercentText"
                       Text="..."
                       FontSize="12"
                       FontWeight="SemiBold"
                       LineHeight="16"
                       Foreground="#FFE8E8E8" />
            <Grid Margin="0,5,0,5">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <TextBlock Text="Cursor"
                           Grid.Column="0"
                           VerticalAlignment="Center"
                           Margin="0,0,8,0"
                           FontFamily="Segoe UI Semibold, Segoe UI, sans-serif"
                           FontSize="11"
                           FontWeight="SemiBold"
                           Foreground="#FFB0B0B0" />
                <Grid x:Name="ProgressTrack"
                      Grid.Column="1"
                      Height="6"
                      VerticalAlignment="Center">
                    <Border CornerRadius="3" Background="#33FFFFFF" />
                    <Border x:Name="ProgressFill"
                            CornerRadius="3"
                            HorizontalAlignment="Left"
                            Width="0"
                            Background="#FF4CAF50" />
                </Grid>
            </Grid>
            <TextBlock x:Name="RemainingText"
                       Text=""
                       FontSize="11"
                       LineHeight="15"
                       Foreground="#FFB0B0B0" />
            <StackPanel Orientation="Horizontal"
                        Margin="0,9,0,0"
                        HorizontalAlignment="Center"
                        Spacing="0">
                <TextBlock Text="built by "
                           FontSize="8.5"
                           LineHeight="12"
                           Foreground="#44FFFFFF"
                           VerticalAlignment="Center" />
                <TextBlock Text="deac.online"
                           FontSize="8.5"
                           LineHeight="12"
                           Foreground="#55AAAAAA"
                           Cursor="Hand"
                           VerticalAlignment="Center"
                           PointerPressed="DeacLink_PointerPressed" />
                <TextBlock Text=" @ "
                           FontSize="8.5"
                           LineHeight="12"
                           Foreground="#44FFFFFF"
                           VerticalAlignment="Center" />
                <TextBlock Text="worldbuild.io"
                           FontSize="8.5"
                           LineHeight="12"
                           Foreground="#55AAAAAA"
                           Cursor="Hand"
                           VerticalAlignment="Center"
                           PointerPressed="WorldbuildLink_PointerPressed" />
            </StackPanel>
        </StackPanel>
    </Border>
</Window>
