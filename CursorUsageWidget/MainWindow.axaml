<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="CursorUsageWidget.MainWindow"
        xmlns:settings="using:CursorUsageWidget.Settings"
        Title="Cursor Usage"
        Width="300"
        SizeToContent="Height"
        ExtendClientAreaChromeHints="NoChrome"
        ExtendClientAreaToDecorationsHint="True"
        TransparencyLevelHint="Transparent"
        Background="Transparent"
        CanResize="False"
        ShowInTaskbar="False"
        Topmost="True"
        PointerPressed="Window_PointerPressed">
    <Border x:Name="PillBorder"
            CornerRadius="10"
            Background="#E6181818"
            BorderBrush="#44FFFFFF"
            BorderThickness="1"
            Padding="10,9,10,12">
        <Border.ContextMenu>
            <ContextMenu>
                <MenuItem Header="Refresh" Click="RefreshMenuItem_Click" />
                <Separator />
                <MenuItem Header="Quit" Click="QuitMenuItem_Click" />
            </ContextMenu>
        </Border.ContextMenu>
        <StackPanel>
            <Grid Margin="0,0,0,6">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0" Orientation="Horizontal">
                    <TextBlock Text="&#x1F701;"
                               FontSize="15"
                               LineHeight="18"
                               Foreground="#CC00E5FF"
                               Margin="0,0,7,0"
                               VerticalAlignment="Center" />
                    <TextBlock Text="Deez Fuel Guage"
                               FontFamily="Segoe UI Semibold, Segoe UI, sans-serif"
                               FontSize="13"
                               FontWeight="SemiBold"
                               LineHeight="18"
                               Foreground="#FF00E5FF"
                               VerticalAlignment="Center" />
                </StackPanel>
                <Border Grid.Column="1"
                        Background="Transparent"
                        Cursor="Hand"
                        Padding="2,0,0,0"
                        PointerPressed="SettingsToggle_PointerPressed">
                    <TextBlock x:Name="SettingsIcon"
                               Text="&#x2699;"
                               FontSize="14"
                               LineHeight="18"
                               Foreground="#FF888888"
                               VerticalAlignment="Center" />
                </Border>
            </Grid>
            <Border x:Name="SettingsPanelHost"
                    Margin="0,0,0,8"
                    Padding="0"
                    CornerRadius="6"
                    Background="Transparent"
                    HorizontalAlignment="Stretch"
                    IsVisible="False">
                <settings:SettingsPanel x:Name="SettingsPanelControl" />
            </Border>
            <StackPanel x:Name="CursorProviderSection">
                <Border x:Name="CursorProviderHeader"
                        Background="Transparent"
                        Cursor="Hand"
                        Margin="0,0,0,4"
                        PointerPressed="CursorProvider_PointerPressed">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Cursor"
                                   Grid.Column="0"
                                   VerticalAlignment="Center"
                                   Margin="0,0,8,0"
                                   FontFamily="Segoe UI Semibold, Segoe UI, sans-serif"
                                   FontSize="11"
                                   FontWeight="SemiBold"
                                   Foreground="#FFB0B0B0" />
                        <Grid x:Name="CursorHeadlineTrack"
                              Grid.Column="1"
                              Height="6"
                              VerticalAlignment="Center">
                            <Border CornerRadius="3" Background="#33FFFFFF" />
                            <Border x:Name="CursorHeadlineFill"
                                    CornerRadius="3"
                                    HorizontalAlignment="Left"
                                    Width="0"
                                    Background="#FF4CAF50" />
                        </Grid>
                    </Grid>
                </Border>
                <StackPanel x:Name="CursorDetailsPanel" IsVisible="False">
            <StackPanel x:Name="CursorSection">
                <TextBlock x:Name="PercentText"
                           Text="..."
                           FontSize="12"
                           FontWeight="SemiBold"
                           LineHeight="16"
                           Foreground="#FFE8E8E8" />
                <Border x:Name="CursorBarBorder"
                        Background="Transparent"
                        PointerPressed="CursorBar_PointerPressed">
                    <Grid Margin="0,5,0,5">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Cursor"
                                   Grid.Column="0"
                                   VerticalAlignment="Center"
                                   Margin="0,0,8,0"
                                   FontFamily="Segoe UI Semibold, Segoe UI, sans-serif"
                                   FontSize="11"
                                   FontWeight="SemiBold"
                                   Foreground="#FFB0B0B0" />
                        <Grid x:Name="ProgressTrack"
                              Grid.Column="1"
                              Height="6"
                              VerticalAlignment="Center">
                            <Border CornerRadius="3" Background="#33FFFFFF" />
                            <Border x:Name="ProgressFill"
                                    CornerRadius="3"
                                    HorizontalAlignment="Left"
                                    Width="0"
                                    Background="#FF4CAF50" />
                        </Grid>
                    </Grid>
                </Border>
                <StackPanel x:Name="BreakdownSection"
                            Margin="0,3,0,0"
                            IsVisible="False">
                    <StackPanel Orientation="Horizontal"
                                Spacing="4">
                        <TextBlock x:Name="BreakdownChevron"
                                   Text="&#x25BE;"
                                   FontSize="10"
                                   LineHeight="14"
                                   Foreground="#FF888888"
                                   VerticalAlignment="Center" />
                        <TextBlock x:Name="BreakdownSummary"
                                   Text=""
                                   FontSize="10"
                                   LineHeight="14"
                                   Foreground="#FF888888"
                                   VerticalAlignment="Center"
                                   TextWrapping="Wrap" />
                    </StackPanel>
                    <Border x:Name="BreakdownPanel"
                            Margin="0,6,0,0"
                            Padding="8,7"
                            CornerRadius="6"
                            Background="#FF121212"
                            IsVisible="False">
                        <StackPanel Spacing="10">
                            <StackPanel>
                                <Grid Margin="0,0,0,4">
                                    <TextBlock Text="Auto + Composer"
                                               FontSize="10"
                                               LineHeight="13"
                                               Foreground="#FFE8E8E8"
                                               HorizontalAlignment="Left" />
                                    <TextBlock x:Name="AutoPercentText"
                                               Text=""
                                               FontSize="10"
                                               LineHeight="13"
                                               Foreground="#FFE8E8E8"
                                               HorizontalAlignment="Right" />
                                </Grid>
                                <Grid x:Name="AutoProgressTrack" Height="5">
                                    <Border CornerRadius="2.5" Background="#33FFFFFF" />
                                    <Border x:Name="AutoProgressFill"
                                            CornerRadius="2.5"
                                            HorizontalAlignment="Left"
                                            Width="0"
                                            Background="#FF4D9FFF" />
                                </Grid>
                                <TextBlock Text="Additional usage beyond limits consumes API quota or on-demand spend."
                                           FontSize="8.5"
                                           LineHeight="12"
                                           Foreground="#FF666666"
                                           TextWrapping="Wrap"
                                           Margin="0,4,0,0" />
                            </StackPanel>
                            <StackPanel>
                                <Grid Margin="0,0,0,4">
                                    <TextBlock Text="API"
                                               FontSize="10"
                                               LineHeight="13"
                                               Foreground="#FFE8E8E8"
                                               HorizontalAlignment="Left" />
                                    <TextBlock x:Name="ApiPercentText"
                                               Text=""
                                               FontSize="10"
                                               LineHeight="13"
                                               Foreground="#FFE8E8E8"
                                               HorizontalAlignment="Right" />
                                </Grid>
                                <Grid x:Name="ApiProgressTrack" Height="5">
                                    <Border CornerRadius="2.5" Background="#33FFFFFF" />
                                    <Border x:Name="ApiProgressFill"
                                            CornerRadius="2.5"
                                            HorizontalAlignment="Left"
                                            Width="0"
                                            Background="#FF4D9FFF" />
                                </Grid>
                                <TextBlock Text="Additional usage beyond limits consumes on-demand spend."
                                           FontSize="8.5"
                                           LineHeight="12"
                                           Foreground="#FF666666"
                                           TextWrapping="Wrap"
                                           Margin="0,4,0,0" />
                            </StackPanel>
                        </StackPanel>
                    </Border>
                </StackPanel>
                <TextBlock x:Name="RemainingText"
                           Text=""
                           FontSize="11"
                           LineHeight="15"
                           Foreground="#FFB0B0B0" />
            </StackPanel>
            <Grid x:Name="OpenAiSection" Margin="0,8,0,4">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <TextBlock Text="OpenAI"
                           Grid.Column="0"
                           VerticalAlignment="Center"
                           Margin="0,0,8,0"
                           FontFamily="Segoe UI Semibold, Segoe UI, sans-serif"
                           FontSize="11"
                           FontWeight="SemiBold"
                           Foreground="#FFB0B0B0" />
                <Grid x:Name="OpenAiProgressTrack"
                      Grid.Column="1"
                      Height="6"
                      VerticalAlignment="Center">
                    <Border CornerRadius="3" Background="#33FFFFFF" />
                    <Border x:Name="OpenAiProgressFill"
                            CornerRadius="3"
                            HorizontalAlignment="Left"
                            Width="0"
                            Background="#FF4CAF50" />
                </Grid>
            </Grid>
            <TextBlock x:Name="OpenAiDetailText"
                       Margin="0,2,0,4"
                       FontSize="9"
                       LineHeight="12"
                       Foreground="#FF777777"
                       IsVisible="False" />
            <Grid x:Name="GeminiSection" Margin="0,0,0,4">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <TextBlock Text="Gemini"
                           Grid.Column="0"
                           VerticalAlignment="Center"
                           Margin="0,0,8,0"
                           FontFamily="Segoe UI Semibold, Segoe UI, sans-serif"
                           FontSize="11"
                           FontWeight="SemiBold"
                           Foreground="#FFB0B0B0" />
                <Grid x:Name="GeminiProgressTrack"
                      Grid.Column="1"
                      Height="6"
                      VerticalAlignment="Center">
                    <Border CornerRadius="3" Background="#33FFFFFF" />
                    <Border x:Name="GeminiProgressFill"
                            CornerRadius="3"
                            HorizontalAlignment="Left"
                            Width="0"
                            Background="#FF4CAF50" />
                </Grid>
            </Grid>
            <TextBlock x:Name="GeminiDetailText"
                       Margin="0,2,0,0"
                       FontSize="9"
                       LineHeight="12"
                       Foreground="#FF777777"
                       IsVisible="False" />
                </StackPanel>
            </StackPanel>
            <StackPanel x:Name="OpenAiProviderSection">
                <Border x:Name="OpenAiProviderHeader"
                        Background="Transparent"
                        Cursor="Hand"
                        Margin="0,0,0,4"
                        PointerPressed="OpenAiProvider_PointerPressed">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="OpenAI"
                                   Grid.Column="0"
                                   VerticalAlignment="Center"
                                   Margin="0,0,8,0"
                                   FontFamily="Segoe UI Semibold, Segoe UI, sans-serif"
                                   FontSize="11"
                                   FontWeight="SemiBold"
                                   Foreground="#FFB0B0B0" />
                        <Grid x:Name="OpenAiHeadlineTrack"
                              Grid.Column="1"
                              Height="6"
                              VerticalAlignment="Center">
                            <Border CornerRadius="3" Background="#33FFFFFF" />
                            <Border x:Name="OpenAiHeadlineFill"
                                    CornerRadius="3"
                                    HorizontalAlignment="Left"
                                    Width="0"
                                    Background="#FF4CAF50" />
                        </Grid>
                    </Grid>
                </Border>
                <StackPanel x:Name="OpenAiDetailsPanel" IsVisible="False">
            <Grid x:Name="OpenAiDirectSection" Margin="0,0,0,4">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <TextBlock Text="OpenAI (direct)"
                           Grid.Column="0"
                           VerticalAlignment="Center"
                           Margin="0,0,8,0"
                           FontFamily="Segoe UI Semibold, Segoe UI, sans-serif"
                           FontSize="11"
                           FontWeight="SemiBold"
                           Foreground="#FFB0B0B0" />
                <Grid x:Name="OpenAiDirectProgressTrack"
                      Grid.Column="1"
                      Height="6"
                      VerticalAlignment="Center">
                    <Border CornerRadius="3" Background="#33FFFFFF" />
                    <Border x:Name="OpenAiDirectProgressFill"
                            CornerRadius="3"
                            HorizontalAlignment="Left"
                            Width="0"
                            Background="#FF4CAF50" />
                </Grid>
            </Grid>
            <TextBlock x:Name="OpenAiDirectDetailText"
                       Margin="0,2,0,4"
                       FontSize="9"
                       LineHeight="12"
                       Foreground="#FF777777"
                       IsVisible="False" />
            <StackPanel x:Name="CodexLimitsSection" IsVisible="False">
                <TextBlock x:Name="CodexPercentText"
                           Text="..."
                           FontSize="12"
                           FontWeight="SemiBold"
                           LineHeight="16"
                           Foreground="#FFE8E8E8" />
                <Border x:Name="CodexBarBorder"
                        Background="Transparent"
                        PointerPressed="CodexLimits_PointerPressed">
                    <Grid Margin="0,5,0,5">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Codex"
                                   Grid.Column="0"
                                   VerticalAlignment="Center"
                                   Margin="0,0,8,0"
                                   FontFamily="Segoe UI Semibold, Segoe UI, sans-serif"
                                   FontSize="11"
                                   FontWeight="SemiBold"
                                   Foreground="#FFB0B0B0" />
                        <Grid x:Name="CodexProgressTrack"
                              Grid.Column="1"
                              Height="6"
                              VerticalAlignment="Center">
                            <Border CornerRadius="3" Background="#33FFFFFF" />
                            <Border x:Name="CodexProgressFill"
                                    CornerRadius="3"
                                    HorizontalAlignment="Left"
                                    Width="0"
                                    Background="#FF4CAF50" />
                        </Grid>
                    </Grid>
                </Border>
                <StackPanel x:Name="CodexBreakdownSection"
                            Margin="0,3,0,0"
                            IsVisible="False">
                    <StackPanel Orientation="Horizontal"
                                Spacing="4">
                        <TextBlock x:Name="CodexBreakdownChevron"
                                   Text="&#x25BE;"
                                   FontSize="10"
                                   LineHeight="14"
                                   Foreground="#FF888888"
                                   VerticalAlignment="Center" />
                        <TextBlock x:Name="CodexBreakdownSummary"
                                   Text=""
                                   FontSize="10"
                                   LineHeight="14"
                                   Foreground="#FF888888"
                                   VerticalAlignment="Center"
                                   TextWrapping="Wrap" />
                    </StackPanel>
                    <Border x:Name="CodexBreakdownPanel"
                            Margin="0,6,0,0"
                            Padding="8,7"
                            CornerRadius="6"
                            Background="#FF121212"
                            IsVisible="False">
                        <StackPanel Spacing="10">
                            <StackPanel>
                                <Grid Margin="0,0,0,4">
                                    <TextBlock Text="5h"
                                               FontSize="10"
                                               LineHeight="13"
                                               Foreground="#FFE8E8E8"
                                               HorizontalAlignment="Left" />
                                    <TextBlock x:Name="CodexSessionPercentText"
                                               Text=""
                                               FontSize="10"
                                               LineHeight="13"
                                               Foreground="#FFE8E8E8"
                                               HorizontalAlignment="Right" />
                                </Grid>
                                <Grid x:Name="CodexSessionProgressTrack" Height="5">
                                    <Border CornerRadius="2.5" Background="#33FFFFFF" />
                                    <Border x:Name="CodexSessionProgressFill"
                                            CornerRadius="2.5"
                                            HorizontalAlignment="Left"
                                            Width="0"
                                            Background="#FF4CAF50" />
                                </Grid>
                                <TextBlock Text="Rolling 5-hour usage window."
                                           FontSize="8.5"
                                           LineHeight="12"
                                           Foreground="#FF666666"
                                           TextWrapping="Wrap"
                                           Margin="0,4,0,0" />
                            </StackPanel>
                            <StackPanel>
                                <Grid Margin="0,0,0,4">
                                    <TextBlock Text="Weekly"
                                               FontSize="10"
                                               LineHeight="13"
                                               Foreground="#FFE8E8E8"
                                               HorizontalAlignment="Left" />
                                    <TextBlock x:Name="CodexWeeklyPercentText"
                                               Text=""
                                               FontSize="10"
                                               LineHeight="13"
                                               Foreground="#FFE8E8E8"
                                               HorizontalAlignment="Right" />
                                </Grid>
                                <Grid x:Name="CodexWeeklyProgressTrack" Height="5">
                                    <Border CornerRadius="2.5" Background="#33FFFFFF" />
                                    <Border x:Name="CodexWeeklyProgressFill"
                                            CornerRadius="2.5"
                                            HorizontalAlignment="Left"
                                            Width="0"
                                            Background="#FF4CAF50" />
                                </Grid>
                                <TextBlock Text="Rolling 7-day usage window."
                                           FontSize="8.5"
                                           LineHeight="12"
                                           Foreground="#FF666666"
                                           TextWrapping="Wrap"
                                           Margin="0,4,0,0" />
                            </StackPanel>
                        </StackPanel>
                    </Border>
                </StackPanel>
                <TextBlock x:Name="CodexRemainingText"
                           Text=""
                           FontSize="11"
                           LineHeight="15"
                           Foreground="#FFB0B0B0" />
            </StackPanel>
                </StackPanel>
            </StackPanel>
            <StackPanel x:Name="GeminiProviderSection">
                <Border x:Name="GeminiProviderHeader"
                        Background="Transparent"
                        Cursor="Hand"
                        Margin="0,0,0,4"
                        PointerPressed="GeminiProvider_PointerPressed">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Gemini"
                                   Grid.Column="0"
                                   VerticalAlignment="Center"
                                   Margin="0,0,8,0"
                                   FontFamily="Segoe UI Semibold, Segoe UI, sans-serif"
                                   FontSize="11"
                                   FontWeight="SemiBold"
                                   Foreground="#FFB0B0B0" />
                        <Grid x:Name="GeminiHeadlineTrack"
                              Grid.Column="1"
                              Height="6"
                              VerticalAlignment="Center">
                            <Border CornerRadius="3" Background="#33FFFFFF" />
                            <Border x:Name="GeminiHeadlineFill"
                                    CornerRadius="3"
                                    HorizontalAlignment="Left"
                                    Width="0"
                                    Background="#FF4CAF50" />
                        </Grid>
                    </Grid>
                </Border>
                <StackPanel x:Name="GeminiDetailsPanel" IsVisible="False">
            <StackPanel x:Name="AntigravityLimitsSection" IsVisible="False">
                <TextBlock x:Name="AntigravityPercentText"
                           Text="..."
                           FontSize="12"
                           FontWeight="SemiBold"
                           LineHeight="16"
                           Foreground="#FFE8E8E8" />
                <Border x:Name="AntigravityBarBorder"
                        Background="Transparent"
                        PointerPressed="AntigravityLimits_PointerPressed">
                    <Grid Margin="0,5,0,5">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Antigravity"
                                   Grid.Column="0"
                                   VerticalAlignment="Center"
                                   Margin="0,0,8,0"
                                   FontFamily="Segoe UI Semibold, Segoe UI, sans-serif"
                                   FontSize="11"
                                   FontWeight="SemiBold"
                                   Foreground="#FFB0B0B0" />
                        <Grid x:Name="AntigravityProgressTrack"
                              Grid.Column="1"
                              Height="6"
                              VerticalAlignment="Center">
                            <Border CornerRadius="3" Background="#33FFFFFF" />
                            <Border x:Name="AntigravityProgressFill"
                                    CornerRadius="3"
                                    HorizontalAlignment="Left"
                                    Width="0"
                                    Background="#FF4CAF50" />
                        </Grid>
                    </Grid>
                </Border>
                <StackPanel x:Name="AntigravityBreakdownSection"
                            Margin="0,3,0,0"
                            IsVisible="False">
                    <StackPanel Orientation="Horizontal"
                                Spacing="4">
                        <TextBlock x:Name="AntigravityBreakdownChevron"
                                   Text="&#x25BE;"
                                   FontSize="10"
                                   LineHeight="14"
                                   Foreground="#FF888888"
                                   VerticalAlignment="Center" />
                        <TextBlock x:Name="AntigravityBreakdownSummary"
                                   Text=""
                                   FontSize="10"
                                   LineHeight="14"
                                   Foreground="#FF888888"
                                   VerticalAlignment="Center"
                                   TextWrapping="Wrap" />
                    </StackPanel>
                    <Border x:Name="AntigravityBreakdownPanel"
                            Margin="0,6,0,0"
                            Padding="8,7"
                            CornerRadius="6"
                            Background="#FF121212"
                            IsVisible="False">
                        <StackPanel Spacing="10">
                            <StackPanel>
                                <Grid Margin="0,0,0,4">
                                    <TextBlock Text="Gemini 5h"
                                               FontSize="10"
                                               LineHeight="13"
                                               Foreground="#FFE8E8E8"
                                               HorizontalAlignment="Left" />
                                    <TextBlock x:Name="AntigravityGeminiSessionPercentText"
                                               Text=""
                                               FontSize="10"
                                               LineHeight="13"
                                               Foreground="#FFE8E8E8"
                                               HorizontalAlignment="Right" />
                                </Grid>
                                <Grid x:Name="AntigravityGeminiSessionProgressTrack" Height="5">
                                    <Border CornerRadius="2.5" Background="#33FFFFFF" />
                                    <Border x:Name="AntigravityGeminiSessionProgressFill"
                                            CornerRadius="2.5"
                                            HorizontalAlignment="Left"
                                            Width="0"
                                            Background="#FF4CAF50" />
                                </Grid>
                            </StackPanel>
                            <StackPanel>
                                <Grid Margin="0,0,0,4">
                                    <TextBlock Text="Gemini weekly"
                                               FontSize="10"
                                               LineHeight="13"
                                               Foreground="#FFE8E8E8"
                                               HorizontalAlignment="Left" />
                                    <TextBlock x:Name="AntigravityGeminiWeeklyPercentText"
                                               Text=""
                                               FontSize="10"
                                               LineHeight="13"
                                               Foreground="#FFE8E8E8"
                                               HorizontalAlignment="Right" />
                                </Grid>
                                <Grid x:Name="AntigravityGeminiWeeklyProgressTrack" Height="5">
                                    <Border CornerRadius="2.5" Background="#33FFFFFF" />
                                    <Border x:Name="AntigravityGeminiWeeklyProgressFill"
                                            CornerRadius="2.5"
                                            HorizontalAlignment="Left"
                                            Width="0"
                                            Background="#FF4CAF50" />
                                </Grid>
                            </StackPanel>
                            <StackPanel>
                                <Grid Margin="0,0,0,4">
                                    <TextBlock Text="3P 5h"
                                               FontSize="10"
                                               LineHeight="13"
                                               Foreground="#FFE8E8E8"
                                               HorizontalAlignment="Left" />
                                    <TextBlock x:Name="AntigravityThirdPartySessionPercentText"
                                               Text=""
                                               FontSize="10"
                                               LineHeight="13"
                                               Foreground="#FFE8E8E8"
                                               HorizontalAlignment="Right" />
                                </Grid>
                                <Grid x:Name="AntigravityThirdPartySessionProgressTrack" Height="5">
                                    <Border CornerRadius="2.5" Background="#33FFFFFF" />
                                    <Border x:Name="AntigravityThirdPartySessionProgressFill"
                                            CornerRadius="2.5"
                                            HorizontalAlignment="Left"
                                            Width="0"
                                            Background="#FF4CAF50" />
                                </Grid>
                            </StackPanel>
                            <StackPanel>
                                <Grid Margin="0,0,0,4">
                                    <TextBlock Text="3P weekly"
                                               FontSize="10"
                                               LineHeight="13"
                                               Foreground="#FFE8E8E8"
                                               HorizontalAlignment="Left" />
                                    <TextBlock x:Name="AntigravityThirdPartyWeeklyPercentText"
                                               Text=""
                                               FontSize="10"
                                               LineHeight="13"
                                               Foreground="#FFE8E8E8"
                                               HorizontalAlignment="Right" />
                                </Grid>
                                <Grid x:Name="AntigravityThirdPartyWeeklyProgressTrack" Height="5">
                                    <Border CornerRadius="2.5" Background="#33FFFFFF" />
                                    <Border x:Name="AntigravityThirdPartyWeeklyProgressFill"
                                            CornerRadius="2.5"
                                            HorizontalAlignment="Left"
                                            Width="0"
                                            Background="#FF4CAF50" />
                                </Grid>
                            </StackPanel>
                        </StackPanel>
                    </Border>
                </StackPanel>
                <TextBlock x:Name="AntigravityRemainingText"
                           Text=""
                           FontSize="11"
                           LineHeight="15"
                           Foreground="#FFB0B0B0" />
            </StackPanel>
                </StackPanel>
            </StackPanel>
            <StackPanel x:Name="OpenRouterProviderSection">
                <Border x:Name="OpenRouterProviderHeader"
                        Background="Transparent"
                        Cursor="Hand"
                        Margin="0,0,0,4"
                        PointerPressed="OpenRouterProvider_PointerPressed">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="OpenRouter"
                                   Grid.Column="0"
                                   VerticalAlignment="Center"
                                   Margin="0,0,8,0"
                                   FontFamily="Segoe UI Semibold, Segoe UI, sans-serif"
                                   FontSize="11"
                                   FontWeight="SemiBold"
                                   Foreground="#FFB0B0B0" />
                        <Grid x:Name="OpenRouterHeadlineTrack"
                              Grid.Column="1"
                              Height="6"
                              VerticalAlignment="Center">
                            <Border CornerRadius="3" Background="#33FFFFFF" />
                            <Border x:Name="OpenRouterHeadlineFill"
                                    CornerRadius="3"
                                    HorizontalAlignment="Left"
                                    Width="0"
                                    Background="#FF4CAF50" />
                        </Grid>
                    </Grid>
                </Border>
                <StackPanel x:Name="OpenRouterDetailsPanel" IsVisible="False">
                    <StackPanel x:Name="OpenRouterLimitsSection" IsVisible="False">
                        <TextBlock x:Name="OpenRouterPercentText"
                                   Text="..."
                                   FontSize="12"
                                   FontWeight="SemiBold"
                                   LineHeight="16"
                                   Foreground="#FFE8E8E8" />
                        <Grid Margin="0,5,0,5">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Credits"
                                       Grid.Column="0"
                                       VerticalAlignment="Center"
                                       Margin="0,0,8,0"
                                       FontFamily="Segoe UI Semibold, Segoe UI, sans-serif"
                                       FontSize="11"
                                       FontWeight="SemiBold"
                                       Foreground="#FFB0B0B0" />
                            <Grid x:Name="OpenRouterProgressTrack"
                                  Grid.Column="1"
                                  Height="6"
                                  VerticalAlignment="Center">
                                <Border CornerRadius="3" Background="#33FFFFFF" />
                                <Border x:Name="OpenRouterProgressFill"
                                        CornerRadius="3"
                                        HorizontalAlignment="Left"
                                        Width="0"
                                        Background="#FF4CAF50" />
                            </Grid>
                        </Grid>
                        <TextBlock x:Name="OpenRouterDetailText"
                                   Margin="0,2,0,4"
                                   FontSize="9"
                                   LineHeight="12"
                                   Foreground="#FF777777"
                                   IsVisible="False" />
                    </StackPanel>
                </StackPanel>
            </StackPanel>
            <StackPanel x:Name="OpenCodeProviderSection">
                <Border x:Name="OpenCodeProviderHeader"
                        Background="Transparent"
                        Cursor="Hand"
                        Margin="0,0,0,4"
                        PointerPressed="OpenCodeProvider_PointerPressed">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="OpenCode"
                                   Grid.Column="0"
                                   VerticalAlignment="Center"
                                   Margin="0,0,8,0"
                                   FontFamily="Segoe UI Semibold, Segoe UI, sans-serif"
                                   FontSize="11"
                                   FontWeight="SemiBold"
                                   Foreground="#FFB0B0B0" />
                        <Grid x:Name="OpenCodeHeadlineTrack"
                              Grid.Column="1"
                              Height="6"
                              VerticalAlignment="Center">
                            <Border CornerRadius="3" Background="#33FFFFFF" />
                            <Border x:Name="OpenCodeHeadlineFill"
                                    CornerRadius="3"
                                    HorizontalAlignment="Left"
                                    Width="0"
                                    Background="#FF4CAF50" />
                        </Grid>
                    </Grid>
                </Border>
                <StackPanel x:Name="OpenCodeDetailsPanel" IsVisible="False">
                    <Grid x:Name="OpenCodeZenSection" Margin="0,0,0,4" IsVisible="False">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Zen"
                                   Grid.Column="0"
                                   VerticalAlignment="Center"
                                   Margin="0,0,8,0"
                                   FontFamily="Segoe UI Semibold, Segoe UI, sans-serif"
                                   FontSize="11"
                                   FontWeight="SemiBold"
                                   Foreground="#FFB0B0B0" />
                        <Grid x:Name="OpenCodeZenProgressTrack"
                              Grid.Column="1"
                              Height="6"
                              VerticalAlignment="Center">
                            <Border CornerRadius="3" Background="#33FFFFFF" />
                            <Border x:Name="OpenCodeZenProgressFill"
                                    CornerRadius="3"
                                    HorizontalAlignment="Left"
                                    Width="0"
                                    Background="#FF4CAF50" />
                        </Grid>
                    </Grid>
                    <TextBlock x:Name="OpenCodeZenDetailText"
                               Margin="0,2,0,4"
                               FontSize="9"
                               LineHeight="12"
                               Foreground="#FF777777"
                               IsVisible="False" />
                    <StackPanel x:Name="OpenCodeGoLimitsSection" IsVisible="False">
                        <TextBlock x:Name="OpenCodeGoPercentText"
                                   Text="..."
                                   FontSize="12"
                                   FontWeight="SemiBold"
                                   LineHeight="16"
                                   Foreground="#FFE8E8E8" />
                        <Border x:Name="OpenCodeGoBarBorder"
                                Background="Transparent"
                                PointerPressed="OpenCodeGoLimits_PointerPressed">
                            <Grid Margin="0,5,0,5">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Go"
                                           Grid.Column="0"
                                           VerticalAlignment="Center"
                                           Margin="0,0,8,0"
                                           FontFamily="Segoe UI Semibold, Segoe UI, sans-serif"
                                           FontSize="11"
                                           FontWeight="SemiBold"
                                           Foreground="#FFB0B0B0" />
                                <Grid x:Name="OpenCodeGoProgressTrack"
                                      Grid.Column="1"
                                      Height="6"
                                      VerticalAlignment="Center">
                                    <Border CornerRadius="3" Background="#33FFFFFF" />
                                    <Border x:Name="OpenCodeGoProgressFill"
                                            CornerRadius="3"
                                            HorizontalAlignment="Left"
                                            Width="0"
                                            Background="#FF4CAF50" />
                                </Grid>
                            </Grid>
                        </Border>
                        <StackPanel x:Name="OpenCodeGoBreakdownSection"
                                    Margin="0,3,0,0"
                                    IsVisible="False">
                            <StackPanel Orientation="Horizontal" Spacing="4">
                                <TextBlock x:Name="OpenCodeGoBreakdownChevron"
                                           Text="&#x25BE;"
                                           FontSize="10"
                                           LineHeight="14"
                                           Foreground="#FF888888"
                                           VerticalAlignment="Center" />
                                <TextBlock x:Name="OpenCodeGoBreakdownSummary"
                                           Text=""
                                           FontSize="10"
                                           LineHeight="14"
                                           Foreground="#FF888888"
                                           VerticalAlignment="Center"
                                           TextWrapping="Wrap" />
                            </StackPanel>
                            <Border x:Name="OpenCodeGoBreakdownPanel"
                                    Margin="0,6,0,0"
                                    Padding="8,7"
                                    CornerRadius="6"
                                    Background="#FF121212"
                                    IsVisible="False">
                                <StackPanel Spacing="10">
                                    <StackPanel>
                                        <Grid Margin="0,0,0,4">
                                            <TextBlock Text="5h"
                                                       FontSize="10"
                                                       LineHeight="13"
                                                       Foreground="#FFE8E8E8"
                                                       HorizontalAlignment="Left" />
                                            <TextBlock x:Name="OpenCodeGoRollingPercentText"
                                                       Text=""
                                                       FontSize="10"
                                                       LineHeight="13"
                                                       Foreground="#FFE8E8E8"
                                                       HorizontalAlignment="Right" />
                                        </Grid>
                                        <Grid x:Name="OpenCodeGoRollingProgressTrack" Height="5">
                                            <Border CornerRadius="2.5" Background="#33FFFFFF" />
                                            <Border x:Name="OpenCodeGoRollingProgressFill"
                                                    CornerRadius="2.5"
                                                    HorizontalAlignment="Left"
                                                    Width="0"
                                                    Background="#FF4CAF50" />
                                        </Grid>
                                    </StackPanel>
                                    <StackPanel>
                                        <Grid Margin="0,0,0,4">
                                            <TextBlock Text="Week"
                                                       FontSize="10"
                                                       LineHeight="13"
                                                       Foreground="#FFE8E8E8"
                                                       HorizontalAlignment="Left" />
                                            <TextBlock x:Name="OpenCodeGoWeeklyPercentText"
                                                       Text=""
                                                       FontSize="10"
                                                       LineHeight="13"
                                                       Foreground="#FFE8E8E8"
                                                       HorizontalAlignment="Right" />
                                        </Grid>
                                        <Grid x:Name="OpenCodeGoWeeklyProgressTrack" Height="5">
                                            <Border CornerRadius="2.5" Background="#33FFFFFF" />
                                            <Border x:Name="OpenCodeGoWeeklyProgressFill"
                                                    CornerRadius="2.5"
                                                    HorizontalAlignment="Left"
                                                    Width="0"
                                                    Background="#FF4CAF50" />
                                        </Grid>
                                    </StackPanel>
                                    <StackPanel>
                                        <Grid Margin="0,0,0,4">
                                            <TextBlock Text="Month"
                                                       FontSize="10"
                                                       LineHeight="13"
                                                       Foreground="#FFE8E8E8"
                                                       HorizontalAlignment="Left" />
                                            <TextBlock x:Name="OpenCodeGoMonthlyPercentText"
                                                       Text=""
                                                       FontSize="10"
                                                       LineHeight="13"
                                                       Foreground="#FFE8E8E8"
                                                       HorizontalAlignment="Right" />
                                        </Grid>
                                        <Grid x:Name="OpenCodeGoMonthlyProgressTrack" Height="5">
                                            <Border CornerRadius="2.5" Background="#33FFFFFF" />
                                            <Border x:Name="OpenCodeGoMonthlyProgressFill"
                                                    CornerRadius="2.5"
                                                    HorizontalAlignment="Left"
                                                    Width="0"
                                                    Background="#FF4CAF50" />
                                        </Grid>
                                    </StackPanel>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                        <TextBlock x:Name="OpenCodeGoRemainingText"
                                   Text=""
                                   FontSize="11"
                                   LineHeight="15"
                                   Foreground="#FFB0B0B0" />
                    </StackPanel>
                </StackPanel>
            </StackPanel>
            <StackPanel x:Name="DiskSection"
                        Margin="0,6,0,0"
                        Spacing="4"
                        IsVisible="False" />
            <StackPanel Orientation="Horizontal"
                        Margin="0,9,0,0"
                        HorizontalAlignment="Center"
                        Spacing="0">
                <TextBlock Text="built by "
                           FontSize="8.5"
                           LineHeight="12"
                           Foreground="#44FFFFFF"
                           VerticalAlignment="Center" />
                <TextBlock Text="deac.online"
                           FontSize="8.5"
                           LineHeight="12"
                           Foreground="#55AAAAAA"
                           Cursor="Hand"
                           VerticalAlignment="Center"
                           PointerPressed="DeacLink_PointerPressed" />
                <TextBlock Text=" @ "
                           FontSize="8.5"
                           LineHeight="12"
                           Foreground="#44FFFFFF"
                           VerticalAlignment="Center" />
                <TextBlock Text="worldbuild.io"
                           FontSize="8.5"
                           LineHeight="12"
                           Foreground="#55AAAAAA"
                           Cursor="Hand"
                           VerticalAlignment="Center"
                           PointerPressed="WorldbuildLink_PointerPressed" />
            </StackPanel>
        </StackPanel>
    </Border>
</Window>
