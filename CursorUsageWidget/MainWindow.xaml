<Window x:Class="CursorUsageWidget.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Cursor Usage"
        Width="230"
        SizeToContent="Height"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        Topmost="True"
        MouseLeftButtonDown="Window_MouseLeftButtonDown">
    <Border x:Name="PillBorder"
            CornerRadius="10"
            Background="#E6181818"
            BorderBrush="#44FFFFFF"
            BorderThickness="1"
            Padding="10,9,10,10">
        <Border.ContextMenu>
            <ContextMenu>
                <MenuItem Header="Refresh" Click="RefreshMenuItem_Click" />
                <Separator />
                <MenuItem Header="Quit" Click="QuitMenuItem_Click" />
            </ContextMenu>
        </Border.ContextMenu>
        <StackPanel>
            <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                <TextBlock Text="&#x1F701;"
                           FontSize="15"
                           LineHeight="18"
                           Foreground="#CC00E5FF"
                           Margin="0,0,7,0"
                           VerticalAlignment="Center" />
                <TextBlock Text="Deez Fuel Guage"
                           FontFamily="Bahnschrift SemiBold, Bahnschrift, Segoe UI Semibold, Segoe UI, sans-serif"
                           FontSize="13"
                           FontWeight="SemiBold"
                           LineHeight="18"
                           Foreground="#FF00E5FF"
                           VerticalAlignment="Center">
                    <TextBlock.Effect>
                        <DropShadowEffect Color="#FF00E5FF"
                                          BlurRadius="8"
                                          ShadowDepth="0"
                                          Opacity="0.55" />
                    </TextBlock.Effect>
                </TextBlock>
            </StackPanel>
            <TextBlock x:Name="PercentText"
                       Text="..."
                       FontSize="12"
                       FontWeight="SemiBold"
                       LineHeight="16"
                       Foreground="#FFE8E8E8" />
            <Grid Margin="0,5,0,5">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <TextBlock Text="Cursor"
                           Grid.Column="0"
                           VerticalAlignment="Center"
                           Margin="0,0,8,0"
                           FontFamily="Bahnschrift, Segoe UI Semibold, Segoe UI, sans-serif"
                           FontSize="11"
                           FontWeight="SemiBold"
                           Foreground="#FFB0B0B0" />
                <Grid x:Name="ProgressTrack"
                      Grid.Column="1"
                      Height="6"
                      VerticalAlignment="Center">
                    <Border CornerRadius="3" Background="#33FFFFFF" />
                    <Border x:Name="ProgressFill"
                            CornerRadius="3"
                            HorizontalAlignment="Left"
                            Width="0"
                            Background="#FF4CAF50" />
                </Grid>
            </Grid>
            <TextBlock x:Name="RemainingText"
                       Text=""
                       FontSize="11"
                       LineHeight="15"
                       Foreground="#FFB0B0B0" />
            <TextBlock FontSize="8.5"
                       LineHeight="12"
                       Foreground="#44FFFFFF"
                       Margin="0,9,0,0"
                       HorizontalAlignment="Center"
                       TextAlignment="Center"
                       TextWrapping="Wrap">
                <Run Text="built by " />
                <Hyperlink NavigateUri="https://deac.online"
                           RequestNavigate="FooterLink_RequestNavigate"
                           Foreground="#55AAAAAA"
                           TextDecorations="None">
                    deac.online
                </Hyperlink>
                <Run Text=" @ " />
                <Hyperlink NavigateUri="https://worldbuild.io"
                           RequestNavigate="FooterLink_RequestNavigate"
                           Foreground="#55AAAAAA"
                           TextDecorations="None">
                    worldbuild.io
                </Hyperlink>
            </TextBlock>
        </StackPanel>
    </Border>
</Window>
