<Window x:Class="CursorUsageWidget.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Cursor Usage"
        Width="200"
        Height="56"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        Topmost="True"
        MouseLeftButtonDown="Window_MouseLeftButtonDown">
    <Border x:Name="PillBorder"
            CornerRadius="10"
            Background="#E6181818"
            BorderBrush="#44FFFFFF"
            BorderThickness="1"
            Padding="10,8">
        <Border.ContextMenu>
            <ContextMenu>
                <MenuItem Header="Refresh" Click="RefreshMenuItem_Click" />
                <Separator />
                <MenuItem Header="Quit" Click="QuitMenuItem_Click" />
            </ContextMenu>
        </Border.ContextMenu>
        <StackPanel>
            <TextBlock x:Name="PercentText"
                       Text="..."
                       FontSize="12"
                       FontWeight="SemiBold"
                       Foreground="#FFE8E8E8" />
            <Grid x:Name="ProgressTrack" Height="6" Margin="0,4,0,4">
                <Border CornerRadius="3" Background="#33FFFFFF" />
                <Border x:Name="ProgressFill"
                        CornerRadius="3"
                        HorizontalAlignment="Left"
                        Width="0"
                        Background="#FF4CAF50" />
            </Grid>
            <TextBlock x:Name="RemainingText"
                       Text=""
                       FontSize="11"
                       Foreground="#FFB0B0B0" />
        </StackPanel>
    </Border>
</Window>
