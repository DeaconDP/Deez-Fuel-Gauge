#!/bin/bash
set -euo pipefail

REPO_ROOT="$(cd "$(dirname "$0")/../../.." && pwd)"
cd "$REPO_ROOT"

show_message() {
    osascript -e "display dialog \"$1\" buttons {\"OK\"} default button \"OK\" with title \"Cursor Usage Widget\""
}

require_dotnet() {
    if command -v dotnet >/dev/null 2>&1; then
        local sdks
        sdks="$(dotnet --list-sdks 2>/dev/null || true)"
        while IFS= read -r line; do
            local version="${line%% *}"
            local major="${version%%.*}"
            if [[ -n "$major" && "$major" -ge 8 ]]; then
                return 0
            fi
        done <<< "$sdks"
    fi

    show_message "The .NET 8 SDK is required. We opened the download page in your browser. Install it, then double-click setup-and-run again."
    open "https://dotnet.microsoft.com/download/dotnet/8.0"
    exit 1
}

launch_widget() {
    local app_path="$REPO_ROOT/CursorUsageWidget/bin/Release/net8.0/CursorUsageWidget"
    if [[ ! -f "$app_path" ]]; then
        show_message "The widget could not be found after building. Try double-clicking setup-and-run again."
        exit 1
    fi

    if [[ ! -x "$app_path" ]]; then
        chmod +x "$app_path"
    fi

    open "$app_path"
}

require_dotnet

if ! dotnet build "$REPO_ROOT/CursorUsageWidget.sln" -c Release --nologo -v q; then
    show_message "Build failed. Make sure the .NET 8 SDK is installed, then double-click setup-and-run again."
    exit 1
fi

launch_widget
